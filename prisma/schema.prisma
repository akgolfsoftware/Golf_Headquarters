// Google Calendar 2-way sync per coach.
// Refresh-token er krypter via GOOGLE_TOKEN_ENCRYPTION_KEY før lagring.
// channelId + resourceId brukes for push-notifikasjons-kanal (V1.5).
model GoogleCalendarConnection {
  id                 String    @id @default(cuid())
  userId             String    @unique
  // Google-konto e-post (typisk akgolfgroup@gmail.com eller anders' personlige)
  googleEmail        String
  // Hvilken kalender brukes som primær (default: "primary")
  calendarId         String    @default("primary")
  // OAuth refresh-token (kryptert via AES-256-GCM)
  refreshTokenCipher String
  // Tidsstempel siste vellykkede sync (busy-times pull)
  lastSyncAt         DateTime?
  // Push-notifications (V1.5 — webhook fra Google ved Calendar-endring)
  channelId          String?
  resourceId         String?
  channelExpiresAt   DateTime?
  // Sync-status: ACTIVE | PAUSED | ERROR
  status             String    @default("ACTIVE")
  lastError          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user          User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions GoogleCalendarSubscription[]

  @@map("google_calendar_connections")
}

// En coach kan ha flere kalendere koblet til Google-kontoen sin. Hver
// subscription representerer én Google-kalender med valgfri push/pull-retning.
//
// - syncPush=true: bookinger pushes til denne kalenderen som nytt event
// - syncPull=true: events i denne kalenderen blokkerer ledige slots
// - watchChannelId/resourceId/expiresAt: Google Push Notifications-state
//   for å motta webhook ved endringer (kun ved syncPull=true).
model GoogleCalendarSubscription {
  id               String    @id @default(cuid())
  connectionId     String
  // Google sin egen calendarId — kan være "primary", e-post eller UUID
  googleCalendarId String
  // Visningsnavn fra Google calendarList.summary
  calendarName     String
  description      String?
  // Hex-farge fra calendarList.backgroundColor (f.eks. "#4285F4")
  color            String?
  // Sync-retning
  syncPush         Boolean   @default(false)
  syncPull         Boolean   @default(true)
  active           Boolean   @default(true)
  // Google Push Notifications watch-tilstand (kun ved syncPull=true)
  watchChannelId   String?
  watchResourceId  String?
  watchExpiresAt   DateTime?
  // Cache av siste sync
  lastSyncAt       DateTime?
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  connection GoogleCalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, googleCalendarId])
  @@index([connectionId, active])
  @@index([watchChannelId])
  @@map("google_calendar_subscriptions")
}

// ---------- CoachHQ-modeller (Fase 2.1) ----------

model Tournament {
  id        String    @id @default(cuid())
  name      String
  // Slug for /turneringer/[slug]-URL. Nullable for legacy-rader uten slug.
  slug      String?   @unique
  startDate DateTime
  endDate   DateTime?
  courseId  String?
  // STROKE | MATCH | STABLEFORD | OTHER
  format    String    @default("STROKE")
  notes     String?

  // /turneringer-felter (synkronisert fra ekstern kilde — DataGolf/NGF/GJGT)
  // Origin: DATAGOLF | NGF | GJGT | VAGR | NCAA | MANUAL
  sourceOrigin String?
  // ID fra kilden (event_id fra DataGolf, golfbox-id fra NGF). Brukes for idempotent sync.
  sourceId     String?
  // Tour: pga | dp | lpga | let | korn-ferry | challenge | amateur-no | junior-no | college
  tour         String?
  // Kursens land (ISO 2-bokstaver)
  country      String?
  location     String?
  latitude     Float?
  longitude    Float?
  // UPCOMING | IN_PROGRESS | COMPLETED | CANCELLED
  status       String?
  winnerName   String?
  officialUrl  String?
  lastSyncAt   DateTime?

  // --- Stats Fase 1: utvidelser for /turneringer + manuell innlegg + merge ---
  // Kort visningsnavn (f.eks. "WGC-FedEx" istedenfor "World Golf Championships - FedEx St. Jude Invitational")
  shortName       String?
  // Premiepott i hele USD (for sortering og display)
  purseUsd        Int?
  // 1=major, 2=tour, 3=challenge, 4=junior, 5=amateur/lokal/klubb
  tier            Int?
  // Mandag i turneringsuken — denormalisert for raskt "denne uken"-søk
  weekStart       DateTime?
  // Antall norske deltakere — denormalisert cache for liste-rendering
  norskeAntall    Int?      @default(0)
  // Hvis sourceOrigin=MANUAL: hvilken bruker (spiller/coach) opprettet turneringen
  createdByUserId String?
  // Hvis denne er en dublett: peker mot kanonisk turnering (coach merger via /admin/tournaments/dubletter)
  mergedIntoId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course          CourseDefinition?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  results         TournamentResult[]
  entries         TournamentEntry[]
  preparations    TournamentPreparation[]
  publicEntries   PublicPlayerEntry[]
  leaderboardSnap LeaderboardSnapshot?

  createdBy       User?                  @relation("ManualTournamentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  mergedInto      Tournament?            @relation("TournamentMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom      Tournament[]           @relation("TournamentMerge")

  @@index([startDate])
  @@index([sourceOrigin, sourceId])
  @@index([tour, status, startDate])
  @@index([weekStart, status])
  @@index([createdByUserId])
  @@index([mergedIntoId])
  @@map("tournaments")
}

// ---------- Banedatabase (Stats Fase) ----------

model Bane {
  id            String   @id @default(cuid())
  slug          String   @unique
  navn          String
  kortNavn      String?
  klubb         String

  // Lokasjon
  region        String   // "Øst" | "Vest" | "Midt" | "Nord" | "Sør"
  kommune       String?
  fylke         String?
  latitude      Float?
  longitude     Float?

  // Bane-info
  antallHull    Int      @default(18)
  oppstartsaar  Int?
  hjemmeside    String?

  // Default tee-data (kan utvides med tee-relasjon senere)
  lengdeMeter   Int?
  slope         Int?
  courseRating  Float?
  par           Int      @default(72)

  // Metadata
  bio           String?  @db.Text
  hovedBilde    String?

  // Stats — denormalisert (oppdateres via cron eller manuelt)
  totaltAntallTurneringer  Int  @default(0)
  spillereSomHarSpilt      Int  @default(0)
  lavesteRundeRegistrert   Int?

  // Banekart-geometri (baneguide) — hele banens GeoJSON FeatureCollection
  // (green/fairway/bunker/tee/hazard) for kart-rendering. Per-hull-data i CourseHole.
  geojson           Json?     // FeatureCollection fra OSM/rette-editor
  osmRelationId     String?   // OSM-id banen ble importert fra
  geometrySource    String?   // "osm" | "manual" | "api"
  geometryUpdatedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  holes             CourseHole[]
  courseDefinitions CourseDefinition[]

  @@index([region])
  @@index([slug])
  @@map("baner")
}

// Ett hull på en bane — geometri + GPS for baneguide/dispersion.
// Tee/green-koordinater driver avstander og plotting; geojson holder
// per-hull-polygoner når de finnes (ellers ligger de på Bane.geojson).
model CourseHole {
  id          String  @id @default(cuid())
  baneId      String
  holeNumber  Int
  par         Int?
  lengthMeter Int?
  handicapIndex Int?  // hull-vanskelighet (1-18) når kjent

  // GPS (WGS84) — tee = start, green = senter, pin = dagens flagg (valgfri)
  teeLat   Float?
  teeLng   Float?
  greenLat Float?
  greenLng Float?
  pinLat   Float?
  pinLng   Float?

  // Per-hull-geometri (green/fairway/bunker-polygoner) hvis tilordnet
  geojson  Json?
  osmWayId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bane Bane @relation(fields: [baneId], references: [id], onDelete: Cascade)

  @@unique([baneId, holeNumber])
  @@index([baneId])
  @@map("course_holes")
}

// Norske + internasjonale spillere vi følger på /turneringer.
// Separat fra User (User = kunder/coacher i PlayerHQ).
model PublicPlayer {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  // ISO 2-bokstavers landkode
  country         String   @default("NO")
  birthYear       Int?
  // Hva spilleren primært spiller: pro-pga | pro-dp | pro-lpga | amateur | junior | college
  tier            String
  // DataGolf player-ID (når vi kobler til pro-leaderboards)
  dataGolfId      Int?     @unique
  // NGF/Golfbox-ID (når vi kobler til amatør-leaderboards)
  ngfId           String?
  // WAGR (World Amateur Golf Ranking) player-ID — for amatør-ranking-kobling.
  wagrId          String?  @unique
  // Kort beskrivelse for spillerprofil-side
  bio             String?
  photoUrl        String?
  instagramHandle String?
  // Skjul fra public listings (men behold data)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entries PublicPlayerEntry[]
  // 0..1 PlayerHQ/test-batteri-bruker koblet til denne turneringsidentiteten.
  linkedUser User?

  @@index([country, tier, isActive])
  @@map("public_players")
}

// Spillerens deltakelse i en turnering — registrert/spiller/ferdig.
model PublicPlayerEntry {
  id           String   @id @default(cuid())
  playerId     String
  tournamentId String
  // REGISTERED | TEED_OFF | CUT | WITHDREW | FINISHED
  status       String   @default("REGISTERED")
  position     Int?
  scoreToPar   Int?
  totalScore   Int?
  // JSON blob med per-runde data
  rounds       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  player       PublicPlayer        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  roundDetails PublicPlayerRound[]

  @@unique([playerId, tournamentId])
  @@index([tournamentId, position])
  @@map("public_player_entries")
}

// Runde-for-runde-resultat + strokes gained per spiller per turnering.
// Fylles fra DataGolf (round-by-round SG) og norske kilder (kun score).
// SG-feltene er null for kilder uten strokes gained.
model PublicPlayerRound {
  id          String   @id @default(cuid())
  entryId     String
  // Rundenummer (1-4).
  roundNumber Int
  score       Int?
  toPar       Int?
  // Strokes Gained — fra DataGolf round-by-round. Null for kilder uten SG.
  sgOtt       Float?
  sgApp       Float?
  sgArg       Float?
  sgPutt      Float?
  sgT2g       Float?
  sgTotal     Float?
  // Tradisjonelle stats hvis tilgjengelig.
  drivingDist Float?
  drivingAcc  Float?
  gir         Float?
  // Origin: DATAGOLF | NGF | MANUAL
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entry PublicPlayerEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, roundNumber])
  @@index([entryId])
  @@map("public_player_rounds")
}

// Cache av siste leaderboard-respons fra DataGolf — JSON-blob så vi kan
// reprosessere uten å hammre API-en. Én rad per turnering.
model LeaderboardSnapshot {
  id           String   @id @default(cuid())
  tournamentId String   @unique
  // Origin: DATAGOLF | NGF | etc.
  source       String
  // Hele JSON-responsen fra API/scraper
  payload      Json
  fetchedAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("leaderboard_snapshots")
}

model TournamentResult {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  position     Int?
  score        Int?
  notes        String?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([userId])
  @@map("tournament_results")
}

// ---------- Sesongplanlegger (Fase 1.18) ----------

model SeasonPlan {
  id        String   @id @default(cuid())
  userId    String
  year      Int // 2025, 2026, …
  name      String? // "Sesong 2025"
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodBlocks      PeriodBlock[]
  tournamentEntries TournamentEntry[]

  @@unique([userId, year])
  @@index([userId])
  @@map("season_plans")
}

model PeriodBlock {
  id           String   @id @default(cuid())
  seasonPlanId String
  lPhase       LPhase // GRUNN|SPESIAL|TURNERING|TESTUKE|FERIE|TRENINGSSAMLING|HELDAGSSAMLING
  startDate    DateTime
  endDate      DateTime
  focus        String? // fri tekst, f.eks. "Putting + kort spill"
  weeklyVolMin Int? // min minutter per uke
  weeklyVolMax Int? // max minutter per uke
  // 8c.1: øktbudsjett per pyramideområde per uke ({"FYS":4,"TEK":2,...}).
  // JSON — zod-valideres ved lesing (lib/workbench/perioder.ts).
  weeklySessionBudget Json?
  notes        String?

  seasonPlan SeasonPlan @relation(fields: [seasonPlanId], references: [id], onDelete: Cascade)

  @@index([seasonPlanId])
  @@map("period_blocks")
}

// 8c.1 (Anders 2026-07-12): gruppens EGEN årsplan — samme tidslinje-UI som
// spillerens, lagret på gruppenivå. Spillerne beholder individuelle planer.
// Plain groupId (FK håndheves i DB-DDL; ingen @relation for å holde
// endringen isolert — jf. gotcha-regelen for additive tabeller).
model GroupPeriodBlock {
  id                  String   @id @default(cuid())
  groupId             String
  lPhase              LPhase
  startDate           DateTime
  endDate             DateTime
  focus               String?
  weeklyVolMin        Int?
  weeklyVolMax        Int?
  weeklySessionBudget Json?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([groupId, startDate])
  @@map("group_period_blocks")
}

model TournamentEntry {
  id              String                @id @default(cuid())
  userId          String
  seasonPlanId    String?
  // Linket til Tournament-katalogen (null = manuell)
  tournamentId    String?
  // Manuelle felter (brukes kun når tournamentId er null)
  manualName      String?
  manualDate      DateTime?
  manualEndDate   DateTime?
  // Felles
  category        String? // "A-rekke", "Åpen NM", "Kretsmesterskap"
  priority        String                @default("NORMAL") // MAJOR | NORMAL | LOCAL
  entryStatus     TournamentEntryStatus @default(PLANNED)
  withdrawnAt     DateTime?
  withdrawnReason String?
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  seasonPlan SeasonPlan? @relation(fields: [seasonPlanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([seasonPlanId])
  @@index([tournamentId])
  @@map("tournament_entries")
}

model Group {
  id              String   @id @default(cuid())
  name            String
  // A1 | A2 | A3 | A4 | A5
  level           String?
  coachId         String?
  maxParticipants Int?     // max deltagere for gruppe-treninger
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  coach     User?           @relation("CoachOfGroup", fields: [coachId], references: [id], onDelete: SetNull)
  members   GroupMember[]
  schedules GroupSchedule[]

  @@index([coachId])
  @@map("groups")
}

// Gruppe-treningstider (Bonus). Brukes for å planlegge faste eller
// ad-hoc gruppe-økter — WANG Toppidrett, GFGK Junior osv.
model GroupSchedule {
  id               String   @id @default(cuid())
  groupId          String
  title            String
  description      String?
  startAt          DateTime
  endAt            DateTime
  location         String?
  // WEEKLY | NONE — for repeterende økter
  recurring        String?
  maxParticipants  Int?
  // SAMLING | HELDAGSSAMLING | null (null = vanlig fast/enkelt-trening)
  kind             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, startAt])
  @@map("group_schedules")
}

// Sesongperioder (Bonus). Fargelegger års-/måneds-/ukekalenderen med
// AK-periodisering (TURN-rest/Testuke/GRUNN/SPES/TURN) per gruppe og skoleår.
model TrainingPeriod {
  id         String   @id @default(cuid())
  // null = gjelder alle grupper. Ingen @relation — se gotchas.md (additiv isolasjon).
  groupId    String?
  // f.eks. "2026/2027"
  schoolYear String
  // TURN-rest | Testuke | GRUNN | SPES | TURN
  name       String
  startDate  DateTime
  endDate    DateTime
  // primary | accent | moss | gold | muted — matcher YearPlanGantt/MonthGrid tone-typer
  tone       String?
  note       String?
  // CompetenceGoal.id — 2-4 kompetansemål periodens treningsplan er bygget rundt
  competenceGoalIds String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([groupId, startDate])
  @@map("training_periods")
}

// Offisielle kompetansemål fra Udir (LK20) for programfaget Toppidrett.
// Referansetabell — økter i Workbench kan lenke til ett eller flere mål.
model CompetenceGoal {
  id             String   @id @default(cuid())
  // VG1 | VG2 | VG3
  classYear      String
  // f.eks. "IDR05-02" (Udir læreplankode)
  curriculumCode String
  // 1-indeksert rekkefølge fra læreplanen
  goalNumber     Int
  text           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([classYear, curriculumCode, goalNumber])
  @@map("competence_goals")
}

// Skolerute, timeplan per fag og prøveplan i én tabell (ett rad-format, ulike
// category-verdier). Konkrete kalenderdager, ikke et fast ukemønster — skolens
// fag-timeplan endres uke for uke. Ingen @relation — additiv isolasjon (gotchas.md).
model SchoolScheduleEntry {
  id         String   @id @default(cuid())
  // VG1 | VG2 | VG3 | null = gjelder alle trinn (skolerute/ferier)
  classYear  String?
  // f.eks. "2026/2027"
  schoolYear String
  date       DateTime
  // TIME | PROVE | HELDAGSPROVE | EKSAMEN | FERIE | SKOLETUR | ANNET
  category   String
  title      String
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([classYear, schoolYear, date])
  @@map("school_schedule_entries")
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  // PLAYER | ASSISTANT
  role     String   @default("PLAYER")
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  subject   String
  body      String // markdown
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  hashedKey  String    @unique
  // første 8 tegn for visning (resten er ikke gjenfinnbar)
  prefix     String
  scopes     Json
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("api_keys")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

// L1 Observability — runtime error-tracking (system errors, ikke user actions)
// Brukes via lib/error-tracking.ts -> logError()
model ErrorLog {
  id         String    @id @default(cuid())
  context    String // "stripe.webhook" | "gcal.sync" | "auth.signup" | etc.
  message    String    @db.Text
  stack      String?   @db.Text
  userId     String? // null = system error, ellers FK til User
  meta       Json? // tilleggsdata (bookingId, sessionId, etc.)
  severity   String    @default("error") // "fatal" | "error" | "warn" | "info"
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([context, createdAt])
  @@index([severity, resolved, createdAt])
  @@index([userId, createdAt])
  @@map("error_logs")
}

model CoachAvailability {
  id        String   @id @default(cuid())
  coachId   String
  // Sted (anlegg) vinduet gjelder for. Nullable = legacy «alle steder».
  // Per-anlegg gjør at en coach aldri er dobbelt-tilgjengelig to steder samtidig.
  locationId String?
  // 0 = mandag, 6 = søndag. Nullable for én-gangs-vinduer (bruker `date`).
  weekday   Int?
  // Én-gangs spesifikk dato (alternativ til ukentlig weekday).
  date      DateTime?
  startTime String // "08:00"
  endTime   String // "18:00"
  // Periode-gyldighet (års-visning): vinduet gjelder kun mellom disse. Null = alltid.
  validFrom DateTime?
  validTo   DateTime?
  // Repetisjon: null/1 = hver uke, 2 = annenhver, 3 = «hver tredje» osv. Ankret
  // til validFrom (ellers fast uke-epoke). Kun for ukentlige vinduer.
  recurrenceInterval Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach    User      @relation(fields: [coachId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([coachId, active])
  @@index([locationId])
  @@map("coach_availability")
}

model Facility {
  id          String       @id @default(cuid())
  locationId  String
  name        String
  capacity    Int          @default(1)
  active      Boolean      @default(true)
  // Type-klassifisering brukt for kart-ikoner, filtrering og statistikk
  // (se FacilityType-enum). Default GENERAL for bakoverkompatibilitet med
  // eksisterende seed-data hvor type ikke var spesifisert.
  type        FacilityType @default(GENERAL)
  // Innendørs vs utendørs. Brukes for værfilter og ikoner.
  isIndoor    Boolean      @default(false)
  // Fritekst-beskrivelse vist i detalj-drawer (utstyr, kapasitet-kommentar).
  description String?
  // Koordinater på anleggskartet (0-100 % av kart-bredde/høyde). Null for
  // fasiliteter som ikke skal vises på kart.
  mapX        Float?
  mapY        Float?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  location Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([locationId, active])
  @@map("facilities")
}

enum FacilityType {
  STUDIO // Performance Studio (indoor TrackMan)
  RANGE_1F // Driving Range 1. etg
  RANGE_2F // Driving Range 2. etg
  PUTTING_GREEN // Putting Green
  SHORT_GAME // Nærspillsområde
  COURSE_9H // 9-hullsbanen
  COURSE_18H // 18-hullsbanen
  SPECIFIC_HOLES // Hull 4/5 etc.
  GENERAL // Fallback for eldre/uklassifiserte fasiliteter
}

model SessionRecording {
  id             String    @id @default(cuid())
  sessionId      String?
  bookingId      String?
  uploadedById   String
  playerId       String?
  // null inntil chunks er merget til final.webm.
  audioUrl       String?
  // [{ idx: number, path: string, size: number }]
  chunks         Json      @default("[]")
  transcript     String?
  durationSec    Int?
  // RECORDING | PROCESSING | DONE | FAILED | ABORTED
  status         String    @default("RECORDING")
  // { teknisk, taktisk, mental, fysisk, hjemmelekse, coachAnalyse, nesteOktAnbefaling }
  aiAnalysis     Json?
  notionPageId   String?
  notes          String?
  retentionUntil DateTime?
  deepgramId     String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  booking    Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  uploadedBy User     @relation("UploadedRecordings", fields: [uploadedById], references: [id], onDelete: Cascade)
  player     User?    @relation("PlayerRecordings", fields: [playerId], references: [id], onDelete: SetNull)

  @@index([uploadedById, createdAt])
  @@index([bookingId])
  @@index([playerId, createdAt])
  @@map("session_recordings")
}

// PlanTemplate-modellen er nå definert tidligere i schema (etter SessionDrill)
// med fullstendig nivå-differensiering og effektivitets-tracking.

// Marketing — leads (Fase 3.3)

model Lead {
  id        String   @id @default(cuid())
  email     String
  name      String?
  // "guide-download" | "newsletter" | "demo-request" | "for-klubber"
  source    String?
  // NEW | CONTACTED | CONVERTED | UNSUBSCRIBED
  status    String   @default("NEW")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([source, status])
  @@map("leads")
}

// WAGR (World Amateur Golf Ranking) snapshot — referansespillere + AK Golf-spillere
// med ekte data fra wagr.com. Snapshot tas periodisk (manuelt eller via cron).
// Brukes for å beregne NGF-kategori og benchmarke AK Golf-spillere mot peer-gruppe.
model WagrSnapshot {
  id             String   @id @default(cuid())
  // URL-slug fra wagr.com (eks "mathias-aase-41993" eller "michael-alexander-mjaaseth-XXXXX")
  wagrPlayerSlug String   @unique
  fullName       String
  // ISO 2-letter country code (no, us, gb, etc.)
  country        String
  // Aktuell WAGR-ranking
  rank           Int
  // Move siden forrige uke (negativ = ned, positiv = opp). Null hvis ny.
  moveDelta      Int?
  // WAGR Pts Avg (poeng-snitt over counting events siste 104 uker)
  ptsAvg         Float
  // Divisor brukt i WAGR-beregningen
  divisor        Float
  // Aggregat-stats fra spillerens profil
  wins           Int      @default(0)
  top10s         Int      @default(0)
  bestRank       Int?
  countingEvents Int      @default(0)
  // Beregnet NGF-kategori (A-L) fra ptsAvg. Oppdateres ved snapshot.
  ngfCategory    String?
  // Hvis koblet til en AK Golf-spiller via email-matching eller manuell kobling
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Når snapshotet ble tatt (manuell eller cron)
  snapshotAt     DateTime @default(now())
  // Metadata: ev. graduationYear, school, hometown, social-media-handles
  metadata       Json?

  @@index([country, rank])
  @@index([ngfCategory])
  @@index([userId])
  @@map("wagr_snapshots")
}

// ---------- Treningsplanlegger (Masterplan Sesjon 0) ----------

model TrainingSessionV2 {
  id                   String                 @id @default(cuid())
  title                String
  studentId            String?
  groupId              String?
  coachId              String
  startTime            DateTime
  endTime              DateTime
  miljo                MMiljo
  practiceType         PracticeType
  status               SessionStatusV2        @default(PLANNED)
  notes                String?
  isCoachCreated       Boolean                @default(true)
  rrule                String?
  recurringGroupId     String?
  isException          Boolean                @default(false)
  generertFra          String?
  generertFraId        String?
  regelBrudd           Json?
  trengerOppmerksomhet Boolean                @default(false)
  drillLoggInterval    Int                    @default(1)
  completedSummary     Json?
  // Trene sammen-feature: delte økter
  isShared             Boolean                @default(false)
  hostId               String?
  host                 User?                  @relation("SessionHost", fields: [hostId], references: [id])
  maxParticipants      Int?
  isPublic             Boolean                @default(false)
  participants         SessionParticipant[]
  drills               TrainingDrillV2[]
  drillInstances       SessionDrillInstance[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([studentId, startTime])
  @@index([coachId, startTime])
  @@index([hostId])
  @@map("training_sessions_v2")
}

// SessionParticipant: spillere invitert til en delt treningsøkt.
// Aktiverer "trene sammen"-feature for kompis-koordinering.
model SessionParticipant {
  id              String                @id @default(cuid())
  sessionId       String
  userId          String
  status          ParticipationStatus   @default(INVITED)
  joinedAt        DateTime?
  respondedAt     DateTime?
  individualNotes String?
  createdAt       DateTime              @default(now())

  session         TrainingSessionV2     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId, status])
  @@index([sessionId])
  @@map("session_participants")
}

enum ParticipationStatus {
  INVITED
  ACCEPTED
  DECLINED
  MAYBE
  ATTENDED
  NO_SHOW
}

// CoachNote: privat notat coach skriver om spiller.
// Persistens for Coach Workbench → Notater-tab.
model CoachNote {
  id        String   @id @default(cuid())
  coachId   String
  playerId  String
  title     String?
  content   String
  tags      String[] @default([])
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach     User     @relation("CoachNoteCoach", fields: [coachId], references: [id], onDelete: Cascade)
  player    User     @relation("CoachNotePlayer", fields: [playerId], references: [id], onDelete: Cascade)

  @@index([coachId, playerId, createdAt])
  @@index([playerId])
  @@map("coach_notes")
}

model TrainingDrillV2 {
  id                  String            @id @default(cuid())
  sessionId           String
  session             TrainingSessionV2 @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sortOrder           Int
  name                String
  description         String?
  durationMinutes     Int
  repetitions         Int?
  drillLoggInterval   Int               @default(1)
  pyramide            PyramidArea
  omraade             String?
  lFase               LFase?
  csNivaa             CSNivaa?
  miljo               MMiljo?
  prPress             PRPress?
  // Rep-type + volum per drill (bølge 2 · 2026-07-04) — kanonisk kontrakt delt med SessionDrill.
  repType             RepType?
  repAntall           Int? // antall svinger (SVINGER_UTEN_BALL) eller baller (BALLER_SLATT)
  repMinutter         Int? // minutter (TID)
  repSett             Int? // sett (SETT_REPS)
  repReps             Int? // reps per sett (SETT_REPS)
  pPosisjoner         String[]
  lifeKode            String?
