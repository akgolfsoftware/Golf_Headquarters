// Abonnement-domenet

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  tier                 Tier               @default(GRATIS)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  // Coaching-abonnement (Performance / Performance Pro):
  // monthlyCredits = antall coaching-timer pakken gir per måned (2 eller 4).
  // creditsRemaining = saldo for inneværende periode. Resettes via webhook
  // når currentPeriodEnd ruller (Stripe-drevet, ingen cron-job).
  // Credits utløper ved månedsskifte (ingen carryover).
  monthlyCredits       Int                @default(0)
  creditsRemaining     Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  payments Payment[]

  @@map("subscriptions")
}

// Sentral Payment-modell — én rad per Stripe payment event.
// Idempotent på Stripe-IDer (paymentIntent/charge/invoice/checkoutSession).
// Penger lagres i øre (Int), aldri Float.
model Payment {
  id                    String         @id @default(cuid())
  stripePaymentIntentId String?        @unique
  stripeChargeId        String?        @unique
  stripeInvoiceId       String?        @unique
  stripeSessionId       String?        @unique
  stripeCustomerId      String?
  amountOre             Int
  amountRefundedOre     Int            @default(0)
  currency              String         @default("nok")
  status                PaymentStatus  @default(PENDING)
  type                  PaymentType
  userId                String?
  bookingId             String?
  subscriptionId        String?
  description           String?
  metadata              Json?
  paidAt                DateTime?
  refundedAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  booking      Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([status])
  @@index([paidAt])
  @@map("payments")
}

