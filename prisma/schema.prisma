  userId    String   @unique
  range     Boolean  @default(true)
  putting   Boolean  @default(true)
  shortgame Boolean  @default(true)
  trackman  Boolean  @default(true)
  course9   Boolean  @default(false)
  course18  Boolean  @default(true)
  gym       Boolean  @default(true)
  yoga      Boolean  @default(false)
  pool      Boolean  @default(false)
  video     Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("facility_prefs")
