  @@index([agentName, createdAt])
  @@map("agent_runs")
}

// Goals/Achievements/Friendship (Fase 1.14)

model Goal {
  id          String       @id @default(cuid())
  userId      String
  // Type: HCP_TARGET | ROUNDS_PER_MONTH | SG_AREA | FREE_TEXT
  type        String
  // Resultatmål (OUTCOME) vs prosessmål (PROCESS).
  // Alle eksisterende mål defaulter til OUTCOME — kan endres manuelt.
  category    GoalCategory @default(OUTCOME)
  title       String
  targetValue Float?
  targetDate  DateTime?
  // Status: ACTIVE | ACHIEVED | ABANDONED
  status      String       @default("ACTIVE")
  payload     Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, category, status])
  @@map("goals")
}

model Achievement {
