// Abonnement-domenet

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  tier                 Tier               @default(GRATIS)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  // Coaching-abonnement (Performance / Performance Pro):
  // monthlyCredits = antall coaching-timer pakken gir per måned (2 eller 4).
  // creditsRemaining = saldo for inneværende periode. Resettes via webhook
  // når currentPeriodEnd ruller (Stripe-drevet, ingen cron-job).
  // Credits utløper ved månedsskifte (ingen carryover).
  monthlyCredits       Int                @default(0)
  creditsRemaining     Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  payments Payment[]

  @@map("subscriptions")
}

// Program-enrollering — kobler spiller til program + coach.
// Én rad per (spiller × program × periode). Historikk beholdes ved endedAt.
// En spiller kan ha flere aktive enrolleringer simultant (mange-til-mange).
// GDPR: PLATFORM_ONLY-enrolleringer har coachId = null og er usynlige i CoachHQ.
model PlayerEnrollment {
  id        String        @id @default(cuid())
  userId    String
  program   PlayerProgram
  // Null for PLATFORM_ONLY. Peker på coach (User med role COACH eller ADMIN).
  coachId   String?
  enrolledAt DateTime     @default(now())
  // Null = aktiv enrollering. Settes ved utmelding — sletter IKKE brukeren.
  endedAt   DateTime?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user  User  @relation("PlayerEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  coach User? @relation("CoachEnrollments", fields: [coachId], references: [id], onDelete: SetNull)

  // Filtrering: aktive enrolleringer per spiller og per coach
  @@index([userId, endedAt])
  @@index([coachId, endedAt])
  @@index([program, endedAt])
  @@map("player_enrollments")
}

// Sentral Payment-modell — én rad per Stripe payment event.
// Idempotent på Stripe-IDer (paymentIntent/charge/invoice/checkoutSession).
// Penger lagres i øre (Int), aldri Float.
model Payment {
  id                    String        @id @default(cuid())
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?       @unique
  stripeInvoiceId       String?       @unique
  stripeSessionId       String?       @unique
  stripeCustomerId      String?
  amountOre             Int
  amountRefundedOre     Int           @default(0)
  currency              String        @default("nok")
  status                PaymentStatus @default(PENDING)
  type                  PaymentType
  userId                String?
  bookingId             String?
  subscriptionId        String?
  description           String?
  metadata              Json?
  paidAt                DateTime?
  refundedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  booking      Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([status])
  @@index([paidAt])
  @@map("payments")
}

