// PlanSession — workbench-spesifikke sessions med drag-drop-persistering (Sprint 6)
model PlanSession {
  id        String   @id @default(cuid())
  userId    String
  planId    String? // valgfri tilknytning til TechnicalPlan
  week      Int // 1-52
  day       Int // 0-6 (mon-sun)
  span      Int      @default(1) // hvor mange dager
  axis      String // "fys" | "tek" | "slag" | "spill" | "turn"
