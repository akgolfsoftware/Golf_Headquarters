  type      String
  title     String
  body      String?
  // Klikkbar destinasjon (relativ URL eller absolutt)
  link      String?
  // Når brukeren markerte den som lest. Null = ulest.
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
