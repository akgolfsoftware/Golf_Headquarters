// TrainingCamp — treningssamling (Workbench Plan A · Sprint 3)
model TrainingCamp {
  id        String   @id @default(cuid())
  userId    String
  name      String
  startDate DateTime
  endDate   DateTime
  location  String?
  partner   String? // "WANG Toppidrett", "Team Norge", "Klubbsamling", "Privat"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@map("training_camps")
}

// ----------------------------------------------------------------------------
// TechnicalPlanPosition — én rad per P1.0 - P10.0 per plan
// ----------------------------------------------------------------------------
model TechnicalPlanPosition {
  id        String @id @default(cuid())
  planId    String
  pNummer   String // "P1.0" - "P10.0"
  navn      String // "Topp-posisjon" - menneskelesbart
  // Ytre prio — drag-and-drop på P-rader. Lavest = øverst.
  sortOrder Int

  // Visuelt flagg — om denne P er hovedfokus (lime venstre-stripe)
  hovedfokus Boolean @default(false)

  plan  TechnicalPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  tasks PositionTask[]

  @@unique([planId, pNummer])
  @@index([planId, sortOrder])
  @@map("technical_plan_positions")
}

// ----------------------------------------------------------------------------
// PositionTask — arbeidsoppgaver innen hver P
// ----------------------------------------------------------------------------
model PositionTask {
  id         String @id @default(cuid())
  positionId String

  // Indre prio — drag-and-drop innen samme P. Lavest = øverst.
  sortOrder Int

  // Innhold
  tittel      String
  beskrivelse String?
  bildeUrl    String? // Supabase Storage
  videoUrl    String? // Supabase Storage eller ekstern lenke

  // Kategorisering
  pyramide PyramidArea
  omraade  String // "Tee Total" | "App 150-200" | "Putt 3-5m" osv. — SG-bucket
  koller   String[] // ["7-jern"] eller ["Alle køller"]
  lFase    LFase? // MORAD lærefase
  cs       CSNivaa? // ferdighet
  miljo    MMiljo? // miljø
  prPress  PRPress? // press-nivå
  slagType String? // "fullsving" | "pitch" | "chip" | "putt" | "bunker" (legacy / fri tekst)
  kategori TaskKategori? // Teknisk/Taktisk/Mentalt/Sosialt — eget felt, erstatter ikke pyramide

  // Rep-mål per hastighet
  repsMaalDry  Int @default(0)
  repsMaalLav  Int @default(0)
  repsMaalFull Int @default(0)

  // Aggregert fremdrift (oppdateres ved log-insert)
  repsGjortDry  Int @default(0)
  repsGjortLav  Int @default(0)
  repsGjortFull Int @default(0)

  // 2-spors status
  status               PositionTaskStatus @default(PENDING)
  trackStatus          TrackStatus        @default(PAA_VEI)
  trackStatusUpdatedAt DateTime?

  // Diagnostisk støtte ved opprettelse
  // [{ metric: string, baseline: number, target: number, support: bool }]
  diagnosticMetrics  Json?
  diagnosticOverride Boolean @default(false) // coach overstyrte TM-evidens

  // Prediksjon
  estimatedCompleteAt DateTime?

  // Sist trent (oppdateres ved hver TrackManShot eller PositionTaskLog)
  lastRepLoggedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  position       TechnicalPlanPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  logs           PositionTaskLog[]
  tmGoals        PositionTaskTmGoal[]
  trackmanShots  TrackManShot[]
  sessionDrills  SessionDrill[]
  trainingDrills TrainingDrillV2[]

  @@index([positionId, sortOrder])
  @@index([status, trackStatus])
  @@map("position_tasks")
}

// ----------------------------------------------------------------------------
// PositionTaskLog — én rad per logget rep (manuelt eller via TrackMan)
// ----------------------------------------------------------------------------
model PositionTaskLog {
  id     String @id @default(cuid())
  taskId String

  // Logger — fra hvilken kontekst
  // Optional fordi reps kan logges manuelt uten session-kontekst
  sessionV2Id    String? // TrainingSessionV2 (live-økt counter)
  trackmanShotId String? @unique // hvis fra TrackMan-import
  loggedByUserId String // hvem klikket logg-knappen / importerte

  reps      Int
  hastighet RepHastighet
  notater   String?

  loggedAt DateTime @default(now())

  task         PositionTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  trackmanShot TrackManShot? @relation(fields: [trackmanShotId], references: [id])

  @@index([taskId, loggedAt])
  @@index([sessionV2Id])
  @@map("position_task_logs")
}

// ----------------------------------------------------------------------------
// PositionTaskTmGoal — TM-mål per oppgave (spredning som primær)
// ----------------------------------------------------------------------------
//
// Coach + spiller setter konkrete TM-mål som måler om den tekniske
// endringen virker. Tre typer mål:
// - PRIMARY: spredningsmål (dispersion, std, axis-avvik)
// - SECONDARY: verdimål (smash mean, ball speed, carry)
// - CAUSAL: tekniske parameter-mål (dynamic loft, attack angle)
//
// Oppgaven anses "TM-ferdig" når ≥3/4 primære nådd + ≥2/3 sekundære
// nådd + stabilt siste 14 dager.
model PositionTaskTmGoal {
  id     String @id @default(cuid())
  taskId String

  metric String // "dispersion_m_std" | "spin_axis_avg_deg" | "smash_factor_mean" | "smash_factor_std" | osv.
  klubb  String // "7-jern" | "Driver" | "Alle køller"

  // Baseline (utgangspunktet)
  baselineValue Float
  baselineFrom  String // "auto-30d" | "manual"
  baselineDate  DateTime
  baselineN     Int? // antall slag baseline bygger på

  // Mål
  targetValue Float
  targetType  TmGoalType
  comparison  TmGoalComparison
  rangeMax    Float? // hvis comparison = RANGE

  // Progress (oppdateres ved hver TM-import)
  currentValue Float?
  progressPct  Int? // 0-100 (hvor mye av baseline → target distansen er dekket)
  inTarget     Boolean   @default(false)
  lastUpdated  DateTime?

  // ----- HIT_RATE-spesifikke felt (Mekanisme 7) -----
  // Pass/fail-protokoll: "8/10 slag innenfor ±2° face angle"
  // Kun relevant når targetType = HIT_RATE.
  protocol         TmGoalProtocol? // ROLLING_WINDOW | BEST_OF_N | STREAK | SESSION_GATE
  windowSize       Int? // antall slag i vinduet (f.eks. 10)
  requiredHits     Int? // antall som må passere (f.eks. 8)
  corridorMin      Float? // nedre grense for "treff" (f.eks. -2.0)
  corridorMax      Float? // øvre grense for "treff" (f.eks. +2.0)
  // Aktuell status — oppdateres etter hver økt
  currentHits      Int? // antall treff i siste vindu
  currentBatchSize Int? // antall slag i siste vindu
  bestHits         Int? // beste resultat i en enkelt økt (for BEST_OF_N)
  currentStreak    Int? // nåværende streak (for STREAK)
  bestStreak       Int? // lengste streak hittil

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task PositionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, targetType])
  @@map("position_task_tm_goals")
}

// ----------------------------------------------------------------------------
// TechnicalPlanClubTarget — TM-mål per kølle for hele planen
// ----------------------------------------------------------------------------
// Ikke knyttet til en spesifikk oppgave — dette er overordnede mål for
// hva spilleren skal oppnå med hver kølle denne perioden.
model TechnicalPlanClubTarget {
  id     String @id @default(cuid())
  planId String

  club String // "Driver" | "7-jern" | "PW" osv.

  // Primær måling (én per kølle — fokus-måling)
  primaryMetric  String // "smashFactor" | "ballSpeed" | "spinRate" osv.
  primaryGoalMin Float?
  primaryGoalMax Float? // null = bare min-grense

  // Sekundære mål — som JSON-array
  // [{ metric, goalMin, goalMax }, ...]
  secondaryGoals Json

  // Aktuelle verdier (oppdateres ved hver TM-sync)
  currentValue   Float?
  currentValueAt DateTime?
  status         ClubTargetStatus @default(IKKE_BEGYNT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan TechnicalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, club])
  @@index([planId, status])
  @@map("technical_plan_club_targets")
}

// ----------------------------------------------------------------------------
// TechnicalPlanAudit — audit-logg for felles redigering
// ----------------------------------------------------------------------------
model TechnicalPlanAudit {
  id      String @id @default(cuid())
  planId  String
  actorId String

  action  String // "TASK_ADD" | "TASK_EDIT" | "PRIO_CHANGE" | "STATUS_CHANGE" osv.
  target  String? // task-id eller andre relevante ID
  payload Json? // før/etter-verdier

  createdAt DateTime @default(now())

  plan  TechnicalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  actor User          @relation(fields: [actorId], references: [id])

  @@index([planId, createdAt])
  @@map("technical_plan_audits")
}

// ----------------------------------------------------------------------------
// TrackManShot — granulær slag-data fra TrackMan-import
// ----------------------------------------------------------------------------
//
// Når en TrackManSession importeres (CSV/API), oppretter vi én TrackManShot
// per slag i sesjonen. Hvert slag matches mot en PositionTask via:
// 1) drill-kontekst (sterkest) — hvis live-økt drill var linket til task
// 2) kølle + område (hovedstrategi)
// 3) manuell tagging (fallback)
//
// Disse driver auto-oppdatering av PositionTask.repsGjort* og
// PositionTaskTmGoal.currentValue.
model TrackManShot {
  id         String @id @default(cuid())
  sessionId  String
  shotNumber Int

  // Slag-identifikasjon
  club String // "7-jern" | "Driver" osv. (parsed fra CSV)

  // Ball-data
  ballSpeed     Float? // mph
  smashFactor   Float?
  launchAngle   Float? // grader
  spinRate      Float? // rpm
  spinAxis      Float? // grader (sidespinn)
  carryDistance Float? // meter
  totalDistance Float? // meter
  apexHeight    Float? // meter
  landAngle     Float? // grader
  side          Float? // meter (dispersion offline)

  // Klubb-data
  clubSpeed      Float? // mph
  attackAngle    Float? // grader
  clubPath       Float? // grader
  faceAngle      Float? // grader
  faceToPath     Float? // grader
  dynamicLoft    Float? // grader
  strikePatternX Float? // -1..1 (toe-heel)
  strikePatternY Float? // -1..1 (low-high)

  // Sync-felt
  positionTaskId  String? // kobling til arbeidsoppgave (null = umatchet)
  matchSource     String? // "auto-club" | "auto-drill" | "manual"
  matchConfidence String? // "high" | "medium" | "low"

  // Klassifisering
  hastighet RepHastighet? // LAV/FULL (basert på Club Speed vs. spillers max)
  outlier   Boolean       @default(false) // ekstrem verdi, ekskludert fra trends

  recordedAt DateTime
  createdAt  DateTime @default(now())

  session TrackManSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  task    PositionTask?    @relation(fields: [positionTaskId], references: [id], onDelete: SetNull)
  log     PositionTaskLog?

  @@index([sessionId, club])
  @@index([positionTaskId, recordedAt])
  @@index([positionTaskId, hastighet])
  @@map("trackman_shots")
}

// ----------------------------------------------------------------------------
// PlanSuggestion — AI Caddie sine forslag til plan-endringer
// ----------------------------------------------------------------------------
//
// Genereres periodisk (etter TM-import + søndag-batch) av Caddie. Coach
// godkjenner / avviser / justerer før de tas inn i planen.
model PlanSuggestion {
  id     String @id @default(cuid())
  planId String

  type     SuggestionType
  payload  Json // forslag-detaljer (task-data, ny prio osv.)
  evidence Json // TM-data og SG-data som backer forslaget

  reason String? // kort menneskelesbar forklaring

  status       SuggestionStatus @default(PENDING)
  decidedAt    DateTime?
  decidedById  String?
  decisionNote String? // justeringer hvis EDITED

  createdAt DateTime @default(now())

  plan      TechnicalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  decidedBy User?         @relation("SuggestionDecider", fields: [decidedById], references: [id])

  @@index([planId, status])
  @@index([type, status])
  @@map("plan_suggestions")
}

// ---------- Webhook retry queue ----------
//
// Når en webhook-handler (Stripe, Google Calendar) feiler internt, lagrer vi
// raw payload + feilmelding her i stedet for å returnere 500 til avsender.
// Da slipper Stripe å spam-retry, og vi kan reprosessere manuelt eller via
// cron-job senere. Status går PENDING → RETRYING → RESOLVED | DEAD.

model WebhookFailure {
  id            String    @id @default(cuid())
  webhookSource String // "stripe" | "google-cal" | annet
  eventId       String    @unique
  payload       Json
  errorMessage  String
  attemptCount  Int       @default(1)
  status        String    @default("PENDING") // PENDING | RETRYING | RESOLVED | DEAD
  lastAttemptAt DateTime  @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, lastAttemptAt])
  @@map("webhook_failures")
}

// ─────────────────────────────────────────────────────────────────
// NOTION SYNC v1.1
//
// Per-user OAuth-tilkobling til Notion. Kun ADMIN bruker dette i v1.1.
// Tasks fra Notion synkes til OppgaveCache hvert 5. min. Coaches uten
// Notion-konto (f.eks. Markus) ser tasks via tekst-match på navnet sitt
// i `tildeltNavn`-feltet (server-side filtrering).
// ─────────────────────────────────────────────────────────────────

enum NotionLinkType {
  OPPGAVER
  PROSJEKTER
}

enum NotionSyncMode {
  AUTO
  MANUELL
  PAUSED
}

model NotionConnection {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Token kryptert med NOTION_ENCRYPTION_KEY (AES-256-GCM)
  accessTokenEnc String
  botId          String?
  workspaceId    String
  workspaceName  String
  workspaceIcon  String?

  lastSyncAt    DateTime?
  lastSyncError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  databases NotionDatabaseLink[]

  @@map("notion_connections")
}

model NotionDatabaseLink {
  id           String           @id @default(cuid())
  connectionId String
  connection   NotionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  notionDatabaseId   String
  notionDataSourceId String?
  navn               String
  type               NotionLinkType @default(OPPGAVER)

  // Property-mapping (Notion property-navn → våre felter)
  propTittel    String  @default("Tittel")
  propStatus    String?
  propPrioritet String?
  propSynlighet String?
  propTildelt   String? // "Eier" som fallback hvis ingen Tildelt-property
  propForfaller String?
  propLenke     String?
  propNotater   String?
  propProsjekt  String?
  propSelskap   String?

  syncMode   NotionSyncMode @default(AUTO)
  lastSyncAt DateTime?
  pagesCount Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  oppgaver OppgaveCache[]

  @@unique([connectionId, notionDatabaseId])
  @@map("notion_database_links")
}

model OppgaveCache {
  id             String             @id @default(cuid())
  databaseLinkId String
  databaseLink   NotionDatabaseLink @relation(fields: [databaseLinkId], references: [id], onDelete: Cascade)

  notionPageId String @unique
  notionUrl    String

  tittel    String
  status    String?
  prioritet String?
  selskap   String[]  @default([])
  forfaller DateTime?
  notater   String?
  lenke     String?

  // Tekst-array — brukes for server-side filtrering for coaches uten Notion-konto
  tildeltNavn String[] @default([])

  // Notion page-IDer (resolved til ProsjektCache.notionPageId)
  prosjektIds String[] @default([])

  notionLastEdited DateTime
  syncedAt         DateTime @default(now())

  @@index([databaseLinkId])
  @@index([notionLastEdited])
  @@map("oppgave_cache")
}

model ProsjektCache {
  id           String @id @default(cuid())
  connectionId String

  notionPageId String @unique
  notionUrl    String

  navn        String
  beskrivelse String?
  status      String?
  selskap     String[] @default([])

  // Aggregert telling fra OppgaveCache
  oppgaverOpen  Int @default(0)
  oppgaverDoing Int @default(0)
  oppgaverDone  Int @default(0)

  notionLastEdited DateTime
  syncedAt         DateTime @default(now())

  @@index([connectionId])
  @@map("prosjekt_cache")
}

// ============================================================================
// FysiskPlan — Fysisk treningsplan (styrke/kondisjon)
// Hierarki: FysiskPlan → FysUke → FysOkt → FysOvelseRad
// Per plan Del 31 (FYS-plan modul, 2026-05-24)
// ============================================================================

model FysiskPlan {
  id            String         @id @default(cuid())
  userId        String
  opprettetAvId String
  navn          String
  status        TechPlanStatus @default(DRAFT)
  startDato     DateTime
  sluttDato     DateTime?
  notater       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User     @relation("FysiskPlanUser", fields: [userId], references: [id], onDelete: Cascade)
  opprettetAv User     @relation("FysiskPlanCreator", fields: [opprettetAvId], references: [id])
  uker        FysUke[]

  @@index([userId, status])
  @@map("fysiske_planer")
}

model FysUke {
  id        String @id @default(cuid())
  planId    String
  ukeNr     Int
  label     String
  sortOrder Int

  plan  FysiskPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  okter FysOkt[]

  @@unique([planId, ukeNr])
  @@index([planId, sortOrder])
  @@map("fys_uker")
}

model FysOkt {
  id               String   @id @default(cuid())
  ukeId            String
  navn             String
  dag              Ukedag?
  sortOrder        Int
  estimertMinutter Int?
  type             String? // styrke | rotasjon | mobilitet | kondisjon (v2 fysisk-logging)

  uke   FysUke         @relation(fields: [ukeId], references: [id], onDelete: Cascade)
  rader FysOvelseRad[]

  @@index([ukeId, sortOrder])
  @@map("fys_okter")
}

model FysOvelseRad {
  id         String  @id @default(cuid())
  oktId      String
  exerciseId String?
  navn       String
  sortOrder  Int

  sett          Int     @default(3)
  repsMin       Int?
  repsMax       Int?
  hvile         Int?
  belastningPst Int?
  rir           Int?
  muskelgruppe  String?

  loggSett         Int?
  loggRepsPerSett  String?
  loggBelastningKg Float?
  loggRir          Int?
  notat            String?

  // v2 fysisk-logging (additivt): ekte per-sett-logg + intervall/puls for kondisjon.
  // Tonnasje/volum beregnes fra loggSettData, lagres ikke.
  loggSettData      Json? // [{ vekt: number, reps: number }] per sett
  intervallSerier   Int?
  intervallMinutter Int?
  pulssone          String? // S1–S5
  pause             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  okt      FysOkt              @relation(fields: [oktId], references: [id], onDelete: Cascade)
  exercise ExerciseDefinition? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)

  @@index([oktId, sortOrder])
  @@map("fys_ovelse_rader")
}

// ============================================================================
// PageApproval — manuell godkjenning av PlayerHQ-sider mot designfiler
// Brukes av /admin/godkjenn-portal for å markere hvilke sider som matcher
// pixel-perfekt mot handover-design.
// ============================================================================

enum ApprovalStatus {
  PENDING
  APPROVED
  MINOR_AVVIK
  MAJOR_AVVIK
  SKIP
}

model PageApproval {
  id           String         @id @default(cuid())
  route        String         @unique
  designPath   String?
  status       ApprovalStatus @default(PENDING)
  notes        String?
  reviewedBy   String?
  reviewedAt   DateTime?
  updatedAt    DateTime       @updatedAt
  createdAt    DateTime       @default(now())

  @@index([status])
  @@map("page_approvals")
}

enum DesignKoblingStatus {
  UNMAPPED
  MAPPED
  APPROVED
  MISSING
  BROKEN
}

model DesignKobling {
  id              String              @id @default(cuid())
  designFile      String              @unique
  designTitle     String
  designH1        String?
  suggestedRoute  String?
  confirmedRoute  String?
  status          DesignKoblingStatus @default(UNMAPPED)
  confidence      Int                 @default(0)
  buttonCount     Int                 @default(0)
  linkCount       Int                 @default(0)
  buttons         Json                @default("[]")
  notes           String?
  approvedBy      String?
  approvedAt      DateTime?
  updatedAt       DateTime            @updatedAt
  createdAt       DateTime            @default(now())

  @@index([status])
  @@index([confirmedRoute])
  @@map("design_koblinger")
}


enum CoachDirektivType {
  PIN
  BLOCK
  PRIORITER
}

/// Coach-direktiv pa en drill for en spiller: PIN (fremhev), BLOCK (skjul), PRIORITER.
/// Unik per coach+spiller+drill+type. Lagres kun via Prisma (server actions); RLS deny-all.
model CoachDrillDirectiv {
  id        String            @id @default(cuid())
  coachId   String
  userId    String
  drillId   String
  type      CoachDirektivType
  kommentar String?
  gyldigTil DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  coach User               @relation("DirektivCoach", fields: [coachId], references: [id], onDelete: Cascade)
  user  User               @relation("DirektivSpiller", fields: [userId], references: [id], onDelete: Cascade)
  drill ExerciseDefinition @relation(fields: [drillId], references: [id], onDelete: Cascade)

  @@unique([coachId, userId, drillId, type], name: "coachId_userId_drillId_type")
  @@index([userId])
  @@index([coachId])
  @@index([drillId])
  @@map("coach_drill_directiv")
}

// ─────────────────────────────────────────────────────────────────────
// Tillegg 2026-06-22 — isolerte additive tabeller (plain id-felt, ingen
// relasjoner, så migrasjonen kun LEGGER TIL og ikke rører eksisterende.)
// ─────────────────────────────────────────────────────────────────────

/// Klubb-innstillinger (singleton — én rad). /admin/klubb/innstillinger.
model ClubSettings {
  id           String   @id @default(cuid())
  clubName     String?
  dagligLeder  String?
  orgNr        String?
  epost        String?
  telefon      String?
  adresse      String?
  apningstider Json? // { man: "08:00-22:00", ... }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("club_settings")
}

/// GDPR: dataeksport- og slette-forespørsler. /forelder/samtykke.
model DataExportRequest {
  id            String   @id @default(cuid())
  userId        String // den som ber (forelder/bruker)
  subjectUserId String? // hvem dataene gjelder (f.eks. barnet)
  type          String // EXPORT | DELETE
  status        String   @default("PENDING") // PENDING | COMPLETED | REJECTED
  createdAt     DateTime @default(now())

  @@index([userId, status])
  @@map("data_export_requests")
}

/// Spiller → coach spørsmål (Q&A). /portal/coach/sporsmal/[id].
model Question {
  id          String    @id @default(cuid())
  askerUserId String // spilleren som spør
  coachUserId String? // coachen spørsmålet er rettet til
  title       String
  body        String
  answer      String?
  status      String    @default("OPEN") // OPEN | ANSWERED
  createdAt   DateTime  @default(now())
  answeredAt  DateTime?

  @@index([coachUserId, status])
  @@index([askerUserId])
  @@map("questions")
}

/// Vedlegg på en coaching-melding (CoachingSession). /portal/coach/melding/[id]/vedlegg.
/// Filer ligger i privat Supabase-bucket "message-attachments"; signed URL ved read.
model MessageAttachment {
  id             String   @id @default(cuid())
  sessionId      String // CoachingSession.id
  uploaderUserId String
  fileName       String
  fileType       String? // MIME
  fileSize       Int? // bytes
  path           String // sti i bucket-en
  createdAt      DateTime @default(now())

  @@index([sessionId])
  @@map("message_attachments")
}

// ---------- AK Agency OS — Kommando (personlig kommandosenter, Etappe 1, 2026-06-25) ----------
// Additive modeller med plain String-FK (ingen @relation) for å holde migrasjonen
// isolert (jf. gotchas.md — CREATE TABLE via scripts/migrate-kommando-tables-2026-06-25.ts).

model KommandoTask {
  id        String    @id @default(cuid())
  userId    String
  projectId String? // reservert for Etappe 2 (Prosjekter)
  title     String
  // "open" | "done"
  status    String    @default("open")
  // "normal" | "haster"
  priority  String    @default("normal")
  dueAt     DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, status, createdAt])
  @@map("kommando_tasks")
}

model KommandoChat {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  model     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@map("kommando_chats")
}

model KommandoMessage {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  // "user" | "assistant"
  role           String
  content        String   @db.Text
  model          String?
  createdAt      DateTime @default(now())

  @@index([userId, conversationId, createdAt])
  @@map("kommando_messages")
}

// Etappe 2 — Prosjekter. KommandoTask.projectId peker hit (plain string-kobling).
model KommandoProject {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String? // valgfri hex/token-nøkkel for fargemerking
  // "active" | "archived"
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status, createdAt])
  @@map("kommando_projects")
}

// Etappe 3 — Agent-team. Flere AI-er jobber sekvensielt på én oppgave.
model KommandoAgentRun {
  id         String    @id @default(cuid())
  userId     String
  projectId  String?
  title      String
  // "running" | "done" | "failed"
  status     String    @default("running")
  createdAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([userId, createdAt])
  @@map("kommando_agent_runs")
}

model KommandoAgentStep {
  id         String    @id @default(cuid())
  runId      String
  orderIndex Int
  model      String
  role       String
  // "pending" | "running" | "done" | "skipped" | "failed"
  status     String    @default("pending")
  output     String?   @db.Text
  createdAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([runId, orderIndex])
  @@map("kommando_agent_steps")
}

// CANON invariant-override (Lag A · 2026-06-30) — coach kan overstyre et HARDT
// invariant-brudd med begrunnelse; logges. Spiller kan aldri overstyre.
// Isolert (ingen @relation) per gotcha — additiv via db execute.
model InvariantOverride {
  id          String   @id @default(cuid())
  invariantId String
  sessionId   String?
  planId      String?
  begrunnelse String
  coachId     String
  opprettet   DateTime @default(now())

  @@index([sessionId])
  @@index([planId])
  @@map("invariant_overrides")
}

// AgencyOS e-post-innboks (2026-07-10) — post@akgolf.no inn på cockpit-
// forsiden. Agent drafter svar automatisk ved inntak; Anders godkjenner og
// sender manuelt (aldri auto-send). Isolert (ingen @relation) per gotcha —
// additiv via db execute.
model InnboksEpost {
  id               String    @id @default(cuid())
  fraEpost         String
  fraNavn          String?
  emne             String
  brodtekst        String    @db.Text
  mottattAt        DateTime  @default(now())
  // "NY" | "UTKAST_KLART" | "SENDT" | "ARKIVERT"
  status           String    @default("NY")
  utkastSvar       String?   @db.Text
  utkastGenerertAt DateTime?
  sendtAt          DateTime?
  sendtAv          String?

  @@index([status, mottattAt])
  @@map("innboks_epost")
}

// Beta-tilbakemelding + support-henvendelser (2026-07-10) — spor F6. Fanger
// opp det som i dag ble kastet på gulvet (kun tekst-lengde i audit-log).
// Isolert (ingen @relation) per gotcha — additiv via db execute.
model AppFeedback {
  id        String   @id @default(cuid())
  userId    String
  // "bug" | "forslag" | "ros" | "sporsmal" | "SUPPORT"
  type      String
  tekst     String   @db.Text
  // Hvilken skjerm/flate tilbakemeldingen kom fra (route eller lesbar kilde).
  side      String?
  // "NY" | "SETT"
  status    String   @default("NY")
  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@map("app_feedback")
}

// AgencyOS marketing-flate (2026-07-13) — M1: innholdskalender + post-kø.
// Én rad per planlagt post (IG/FB/LinkedIn/TikTok). Ingen auto-publisering —
// status settes manuelt av coach. Isolert (ingen @relation) per gotcha —
// additiv via db execute (scripts/migrate-marketing-posts-2026-07-13.ts).
model MarketingPost {
  id          String   @id @default(cuid())
  title       String
  // "IG" | "FB" | "LINKEDIN" | "TIKTOK"
  channel     String
  scheduledAt DateTime
  brief       String?  @db.Text
  // "UTKAST" | "KLAR" | "PUBLISERT"
  status      String   @default("UTKAST")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scheduledAt])
  @@map("marketing_posts")
}
