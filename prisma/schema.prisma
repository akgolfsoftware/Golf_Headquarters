// ---------- AK Golf Stats — Fase 2 PGA Tour playground ----------
// Sesong-aggregat per spiller per år per tour. Brukes til /stats/pga
// topplister og interaktive sammenligninger (drive distance, fairway %, GIR,
// putts, scoring avg, SG-fordeling).
// Synket ukentlig fra DataGolf /preds/skill-ratings.
model PgaPlayerSeason {
  id            String   @id @default(cuid())
  dgPlayerId    Int
  // Tour-slug: pga | euro | kft | alt | champ | liv
  tour          String
  year          Int
  playerName    String
  country       String?

  // Sesong-summer
  rounds        Int?
  // Stat-felter (alle valgfrie — DataGolf returnerer ikke alle for alle spillere)
  avgScore      Float?
  driveDist     Float?      // gjennomsnittlig driving distance (yards)
  fairwayPct    Float?      // 0-100
  girPct        Float?      // 0-100
  puttsPerRound Float?
  scrambling    Float?      // 0-100

  // Strokes Gained-fordeling (per runde)
  sgTotal       Float?
  sgOtt         Float?
  sgApp         Float?
  sgArg         Float?
  sgPutt        Float?

  // Metadata
  source        String      @default("datagolf")
  lastUpdated   DateTime    @default(now()) @updatedAt

  @@unique([dgPlayerId, tour, year])
  @@index([tour, year, driveDist])
  @@index([tour, year, sgTotal])
  @@index([tour, year, fairwayPct])
  @@index([tour, year, girPct])
  @@index([tour, year, puttsPerRound])
  @@index([tour, year, avgScore])
  @@map("pga_player_seasons")
}

// Putt-statistikk per avstand (meter) — Broadie-estimater seeded manuelt,
// oppdateres via cron hvis DataGolf eksponerer et putt-distance-endepunkt.
// Brukes til /stats/pga/putt-explorer.
model PgaPuttDistance {
  id              String   @id @default(cuid())
  year            Int
  distanceMeters  Int      // 1, 2, 3, 5, 8, 10, 15, 20
  tourAvgSunkPct  Float    // 0-100
  top10AvgSunkPct Float?   // 0-100 (topp 10 putters)
  proximityNext   Float?   // gjennomsnittlig proximity i meter til neste putt
  source          String   @default("broadie-estimate")
  lastUpdated     DateTime @default(now()) @updatedAt

  @@unique([year, distanceMeters])
  @@map("pga_putt_distance")
}

// Approach-statistikk per yardage-bøtte — proximity til hull + GIR%.
// Hentes fra DataGolf /preds/approach-skill aggregert per bucket.
// Brukes til fremtidig /stats/pga/approach-distance-side.
model PgaApproachDistance {
  id                     String   @id @default(cuid())
  year                   Int
  // Bøtte-grenser i yards: "50-75", "75-100", "100-125", osv.
  yardageBucket          String
  tourAvgProximityMeters Float    // gjennomsnittlig proximity til hull
  girPct                 Float?   // 0-100
  source                 String   @default("datagolf-approach-skill")
  lastUpdated            DateTime @default(now()) @updatedAt

  @@unique([year, yardageBucket])
  @@map("pga_approach_distance")
}

