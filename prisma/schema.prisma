  slowMotionMode      Boolean           @default(false)
  fysTreningstype     String?
  fysMuskelgruppe     String?
  fysOvelse           String?
  fysSett             Int?
  fysReps             Int?
  fysVektKg           Float?
  fysVektProsent      Int?
