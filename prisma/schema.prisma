// AK Golf HQ — Prisma schema
// Foundation: 4 startmodeller. Resten migreres inn i egen fase.
// Prisma 7: url/directUrl flyttet til prisma.config.ts. Schema har bare provider.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum UserRole {
  ADMIN
  COACH
  PLAYER
  PARENT
  GUEST
}

enum Tier {
  GRATIS
  PRO
  ELITE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// PlayerHQ-domenet (Fase 1.5)

enum SessionStatus {
  PLANNED
  ACTIVE
  COMPLETED
  SKIPPED
  CANCELLED
}

enum PyramidArea {
  FYS
  TEK
  SLAG
  SPILL
  TURN
}

enum LPhase {
  KROPP
  ARM
  KOLLE
  BALL
  AUTO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum PlanStatus {
  DRAFT           // Coach jobber på planen
  PENDING_PLAYER  // Sendt til spiller for godkjenning
  ACCEPTED        // Spiller har godtatt, klar til å starte
  REJECTED        // Spiller ba om endring (se playerComment)
  ACTIVE          // Pågående
  PAUSED          // Midlertidig pause
  ARCHIVED        // Ferdig eller avsluttet
}

// ---------- Models ----------

model User {
  id          String    @id @default(cuid())
  // Knytter mot Supabase auth.users.id (UUID).
  // Holdes som String for å unngå Prisma-uuid-type-friksjon mot Supabase.
  authId      String    @unique
  email       String    @unique
  name        String
  phone       String?
  avatarUrl   String?
  role        UserRole  @default(PLAYER)
  tier        Tier      @default(GRATIS)
  lastLoginAt DateTime?
  // Spiller-profil (Fase 1.4)
  hcp          Float?
  playingYears Int?
  ambition     String?
  homeClub     String?
  // Bruker-preferanser (notifikasjoner, språk, etc.) som flexibel JSON.
  // Strukturen håndheves i kode (src/lib/preferences.ts) ikke i DB.
  preferences  Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bookings        Booking[]
  parentRelations ParentRelation[] @relation("Child")
  childRelations  ParentRelation[] @relation("Parent")

  // PlayerHQ-relasjoner
  trainingPlans     TrainingPlan[]
  rounds            Round[]
  testResults       TestResult[]
  trackManSessions  TrackManSession[]
  subscription      Subscription?

  // Coaching-relasjoner
  playerCoachingSessions CoachingSession[] @relation("PlayerCoachingSessions")
  coachCoachingSessions  CoachingSession[] @relation("CoachCoachingSessions")

  // Agent-relasjoner
  signals     Signal[]
  planActions PlanAction[]

  // Goals/achievements/sosiale (Fase 1.14)
  goals        Goal[]
  achievements Achievement[]
  friendshipsA Friendship[] @relation("FriendshipUserA")
  friendshipsB Friendship[] @relation("FriendshipUserB")

  // Documents og session-requests (Fase 1.17)
  documents       Document[]
  sessionRequests SessionRequest[]

  // CoachHQ-relasjoner (Fase 2.1)
  tournamentResults TournamentResult[]
  coachedGroups     Group[]            @relation("CoachOfGroup")
  groupMemberships  GroupMember[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  coachAvailability CoachAvailability[]

  @@map("users")
}

// Foresatt-spiller relasjon (junior har ofte 1-2 foresatte; voksen kan ha 0)
model ParentRelation {
  id           String   @id @default(cuid())
  parentId     String
  childId      String
  relationship String   @default("Foresatt") // Foresatt, Trener, Søsken
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent User @relation("Parent", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("Child", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([childId])
  @@map("parent_relations")
}

model ServiceType {
  id          String   @id @default(cuid())
  // Public slug for booking-URL (/booking/[slug])
  slug        String   @unique
  name        String
  // Pris i ØRE (Int). Aldri Float for penger. Format i UI: priceOre / 100.
  priceOre    Int
  durationMin Int
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("service_types")
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings   Booking[]
  facilities Facility[]

  @@map("locations")
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  serviceTypeId String
  locationId    String
  startAt       DateTime
  endAt         DateTime
  status        BookingStatus @default(PENDING)
  notes         String?
  // Pris låst ved booking (i øre, ikke Float). Refusjonsbeløp baseres på dette.
  // For credit-baserte bookinger fra Academy-abonnement: priceOre = 0.
  priceOre      Int           @default(0)
  // Stripe-tracking. CheckoutSession før betaling, PaymentIntent etter.
  // Null for credit-baserte abonnement-bookinger.
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  // Hvis booking er trukket fra Academy-abonnement, peker dette tilbake til
  // Subscription. Brukes for credit-tilbakeføring ved avbestilling >24t.
  subscriptionId String?
  // Kontakt-info for bookinger gjort av ikke-innloggede kunder (gjest-flow).
  guestName     String?
  guestEmail    String?
  guestPhone    String?
  // Sletting av brukerkonto skal ikke slette historiske bookinger — sett userId til null.
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  serviceType  ServiceType   @relation(fields: [serviceTypeId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([startAt])
  @@index([stripeCheckoutSessionId])
  @@index([subscriptionId])
  @@map("bookings")
}

// ---------- PlayerHQ-modeller (Fase 1.5) ----------

model TrainingPlan {
  id          String     @id @default(cuid())
  userId      String
  name        String
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean    @default(true)
  // Status-enum for godkjennings-flyt mellom coach og spiller.
  // DRAFT → PENDING_PLAYER → ACCEPTED → ACTIVE → ARCHIVED.
  // REJECTED hvis spiller ber om endring (se playerComment).
  status      PlanStatus @default(DRAFT)
  // Kommentar fra spiller ved REJECTED.
  playerComment String?
  // Coach-id (User med role=COACH) hvis plan opprettet av coach. Ikke FK i v1
  // for å holde det enkelt — modelleres som relasjon i Fase 1.9.
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    TrainingPlanSession[]
  planActions PlanAction[]

  @@index([userId, isActive])
  @@index([status])
  @@map("training_plans")
}

model TrainingPlanSession {
  id          String        @id @default(cuid())
  planId      String
  scheduledAt DateTime
  durationMin Int
  title       String
  rationale   String?
  pyramidArea PyramidArea
  status      SessionStatus @default(PLANNED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  plan   TrainingPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  drills SessionDrill[]
  log    TrainingPlanSessionLog?

  @@index([planId, scheduledAt])
  @@map("training_plan_sessions")
}

model ExerciseDefinition {
  id              String      @id @default(cuid())
  name            String
  description     String?
  videoUrl        String?
  pyramidArea     PyramidArea
  lPhase          LPhase
  defaultRepsSets String?
  csMin           Int?
  csMax           Int?
  createdAt       DateTime    @default(now())

  sessionDrills SessionDrill[]

  @@index([pyramidArea])
  @@map("exercise_definitions")
}

model SessionDrill {
  id         String  @id @default(cuid())
  sessionId  String
  exerciseId String
  repsSets   String
  csTarget   Int?
  notes      String?
  orderIndex Int     @default(0)

  session  TrainingPlanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise ExerciseDefinition  @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@map("session_drills")
}

model TrainingPlanSessionLog {
  id          String    @id @default(cuid())
  sessionId   String    @unique
  startedAt   DateTime
  completedAt DateTime?
  csAchieved  Int?
  notes       String?
  rating      Int? // 1-5
  createdAt   DateTime  @default(now())

  session TrainingPlanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("training_plan_session_logs")
}

// Mål-domenet

model CourseDefinition {
  id        String   @id @default(cuid())
  name      String
  par       Int
  rating    Float?
  slope     Int?
  createdAt DateTime @default(now())

  rounds      Round[]
  tournaments Tournament[]

  @@map("course_definitions")
}

model Round {
  id       String   @id @default(cuid())
  userId   String
  courseId String
  playedAt DateTime
  score    Int
  sgTotal  Float?
  sgOtt    Float?
  sgApp    Float?
  sgArg    Float?
  sgPutt   Float?
  notes    String?
  createdAt DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course CourseDefinition @relation(fields: [courseId], references: [id])

  @@index([userId, playedAt])
  @@map("rounds")
}

model TestDefinition {
  id          String      @id @default(cuid())
  name        String
  description String?
  pyramidArea PyramidArea
  scoringRule String
  createdAt   DateTime    @default(now())

  results TestResult[]

  @@map("test_definitions")
}

model TestResult {
  id        String   @id @default(cuid())
  userId    String
  testId    String
  takenAt   DateTime
  score     Float
  notes     String?
  createdAt DateTime @default(now())

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  test TestDefinition @relation(fields: [testId], references: [id])

  @@index([userId, takenAt])
  @@map("test_results")
}

model TrackManSession {
  id         String   @id @default(cuid())
  userId     String
  recordedAt DateTime
  source     String // "csv-import" | "api"
  shotCount  Int      @default(0)
  rawJson    Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@map("trackman_sessions")
}

// Agent-pipeline (Fase 1.12)

model Signal {
  id         String   @id @default(cuid())
  userId     String
  // Type signal: SG_TOTAL | SG_AREA | HCP_TREND | CLUB_AVG | PYRAMID_AREA | STREAK
  kind       String
  value      Float?
  payload    Json?
  computedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, computedAt])
  @@map("signals")
}

model PlanAction {
  id         String   @id @default(cuid())
  userId     String
  planId     String?
  // Type: PYRAMID_ADJUST | SESSION_ADD | SESSION_REMOVE | INTENSITY_ADJUST
  //       | TAPER_ENGAGE | WITHDRAW | DRILL_SUGGEST | TEST_SCHEDULE
  //       | PEER_COMPARE | RECOVERY_ADD
  actionType String
  suggestion Json
  // Status: PENDING | ACCEPTED | REJECTED
  status     String   @default("PENDING")
  agentName  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan TrainingPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@map("plan_actions")
}

model AgentRun {
  id        String   @id @default(cuid())
  agentName String
  userId    String?
  status    String // OK | ERROR
  duration  Int // ms
  output    Json?
  error     String?
  createdAt DateTime @default(now())

  @@index([agentName, createdAt])
  @@map("agent_runs")
}

// Goals/Achievements/Friendship (Fase 1.14)

model Goal {
  id          String    @id @default(cuid())
  userId      String
  // Type: HCP_TARGET | ROUNDS_PER_MONTH | SG_AREA | FREE_TEXT
  type        String
  title       String
  targetValue Float?
  targetDate  DateTime?
  // Status: ACTIVE | ACHIEVED | ABANDONED
  status      String    @default("ACTIVE")
  payload     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("goals")
}

model Achievement {
  id       String   @id @default(cuid())
  userId   String
  // STREAK_7 | STREAK_14 | FIRST_ROUND | SG_POSITIVE_30D | FIRST_TEST | etc.
  kind     String
  earnedAt DateTime @default(now())
  payload  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@index([userId, earnedAt])
  @@map("achievements")
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  // PENDING | ACCEPTED | BLOCKED
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  userA User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@map("friendships")
}

// Documents + session-requests (Fase 1.17)

model Document {
  id        String   @id @default(cuid())
  // null = global (kontrakter, vilkår tilgjengelig for alle)
  userId    String?
  title     String
  url       String
  // CONTRACT | GUIDE | RECEIPT | OTHER
  kind      String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, kind])
  @@map("documents")
}

model SessionRequest {
  id          String    @id @default(cuid())
  userId      String
  coachId     String?
  preferredAt DateTime?
  pyramidArea String?
  notes       String?
  // PENDING | SCHEDULED | DECLINED
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("session_requests")
}

// Coach-domenet (Fase 1.9)

model CoachingSession {
  id        String   @id @default(cuid())
  userId    String
  coachId   String
  // messages: array av { role: "user" | "assistant" | "coach" | "system", content: string, ts: ISO }
  messages  Json     @default("[]")
  kind      String   @default("AI") // "AI" | "DIRECT"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User @relation("PlayerCoachingSessions", fields: [userId], references: [id], onDelete: Cascade)
  coach User @relation("CoachCoachingSessions", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("coaching_sessions")
}

// Abonnement-domenet

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  tier                 Tier               @default(GRATIS)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  // Coaching-abonnement (Performance / Performance Pro):
  // monthlyCredits = antall coaching-timer pakken gir per måned (2 eller 4).
  // creditsRemaining = saldo for inneværende periode. Resettes via webhook
  // når currentPeriodEnd ruller (Stripe-drevet, ingen cron-job).
  // Credits utløper ved månedsskifte (ingen carryover).
  monthlyCredits       Int                @default(0)
  creditsRemaining     Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("subscriptions")
}

// ---------- CoachHQ-modeller (Fase 2.1) ----------

model Tournament {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime?
  courseId  String?
  // STROKE | MATCH | STABLEFORD | OTHER
  format    String   @default("STROKE")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  CourseDefinition?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  results TournamentResult[]

  @@index([startDate])
  @@map("tournaments")
}

model TournamentResult {
  id           String  @id @default(cuid())
  tournamentId String
  userId       String
  position     Int?
  score        Int?
  notes        String?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([userId])
  @@map("tournament_results")
}

model Group {
  id        String   @id @default(cuid())
  name      String
  // A1 | A2 | A3 | A4 | A5
  level     String?
  coachId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach   User?         @relation("CoachOfGroup", fields: [coachId], references: [id], onDelete: SetNull)
  members GroupMember[]

  @@index([coachId])
  @@map("groups")
}

model GroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String
  // PLAYER | ASSISTANT
  role    String @default("PLAYER")
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  subject   String
  body      String   // markdown
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  hashedKey  String    @unique
  // første 8 tegn for visning (resten er ikke gjenfinnbar)
  prefix     String
  scopes     Json
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("api_keys")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model CoachAvailability {
  id        String   @id @default(cuid())
  coachId   String
  // 0 = mandag, 6 = søndag
  weekday   Int
  startTime String // "08:00"
  endTime   String // "18:00"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach User @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId, active])
  @@map("coach_availability")
}

model Facility {
  id         String   @id @default(cuid())
  locationId String
  name       String
  capacity   Int      @default(1)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, active])
  @@map("facilities")
}

model SessionRecording {
  id           String   @id @default(cuid())
  sessionId    String?
  uploadedById String
  audioUrl     String
  transcript   String?
  duration     Int?
  // PROCESSING | DONE | FAILED
  status       String   @default("PROCESSING")
  deepgramId   String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([uploadedById, createdAt])
  @@map("session_recordings")
}

model PlanTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  weeks       Int
  // payload: array av { week, day, title, pyramidArea, durationMin, drills:[{exerciseId, repsSets}] }
  payload     Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plan_templates")
}

// Marketing — leads (Fase 3.3)

model Lead {
  id        String   @id @default(cuid())
  email     String
  name      String?
  // "guide-download" | "newsletter" | "demo-request" | "for-klubber"
  source    String?
  // NEW | CONTACTED | CONVERTED | UNSUBSCRIBED
  status    String   @default("NEW")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([source, status])
  @@map("leads")
}
