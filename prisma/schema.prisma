  userId   String
  // STREAK_7 | STREAK_14 | FIRST_ROUND | SG_POSITIVE_30D | FIRST_TEST | etc.
  kind     String
  earnedAt DateTime @default(now())
  payload  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@index([userId, earnedAt])
  @@map("achievements")
}

model Friendship {
