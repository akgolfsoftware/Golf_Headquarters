// In-app varsler. Brukes for booking-bekreftelser, plan-godkjenninger,
// achievements, coach-meldinger osv. Vises i Bell-dropdown og /portal/varsler.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  // Type-tag for ikon/farge i UI (booking, plan, achievement, melding, system, ...)
  type      String
  title     String
  body      String?
  // Klikkbar destinasjon (relativ URL eller absolutt)
  link      String?
  // Når brukeren markerte den som lest. Null = ulest.
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

// Google Calendar 2-way sync per coach.
// Refresh-token er krypter via GOOGLE_TOKEN_ENCRYPTION_KEY før lagring.
// channelId + resourceId brukes for push-notifikasjons-kanal (V1.5).
model GoogleCalendarConnection {
  id                   String   @id @default(cuid())
  userId               String   @unique
  // Google-konto e-post (typisk akgolfgroup@gmail.com eller anders' personlige)
  googleEmail          String
  // Hvilken kalender brukes som primær (default: "primary")
  calendarId           String   @default("primary")
  // OAuth refresh-token (kryptert via AES-256-GCM)
  refreshTokenCipher   String
  // Tidsstempel siste vellykkede sync (busy-times pull)
  lastSyncAt           DateTime?
  // Push-notifications (V1.5 — webhook fra Google ved Calendar-endring)
  channelId            String?
  resourceId           String?
  channelExpiresAt     DateTime?
  // Sync-status: ACTIVE | PAUSED | ERROR
  status               String   @default("ACTIVE")
  lastError            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions GoogleCalendarSubscription[]

  @@map("google_calendar_connections")
}

// En coach kan ha flere kalendere koblet til Google-kontoen sin. Hver
// subscription representerer én Google-kalender med valgfri push/pull-retning.
//
// - syncPush=true: bookinger pushes til denne kalenderen som nytt event
// - syncPull=true: events i denne kalenderen blokkerer ledige slots
// - watchChannelId/resourceId/expiresAt: Google Push Notifications-state
//   for å motta webhook ved endringer (kun ved syncPull=true).
model GoogleCalendarSubscription {
  id               String   @id @default(cuid())
  connectionId     String
  // Google sin egen calendarId — kan være "primary", e-post eller UUID
  googleCalendarId String
  // Visningsnavn fra Google calendarList.summary
  calendarName     String
  description      String?
  // Hex-farge fra calendarList.backgroundColor (f.eks. "#4285F4")
  color            String?
  // Sync-retning
  syncPush         Boolean  @default(false)
  syncPull         Boolean  @default(true)
  active           Boolean  @default(true)
  // Google Push Notifications watch-tilstand (kun ved syncPull=true)
  watchChannelId   String?
  watchResourceId  String?
  watchExpiresAt   DateTime?
  // Cache av siste sync
  lastSyncAt       DateTime?
  lastError        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  connection GoogleCalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, googleCalendarId])
  @@index([connectionId, active])
  @@index([watchChannelId])
  @@map("google_calendar_subscriptions")
}

