// AK Golf HQ — Prisma schema
// Foundation: 4 startmodeller. Resten migreres inn i egen fase.
// Prisma 7: url/directUrl flyttet til prisma.config.ts. Schema har bare provider.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum UserRole {
  ADMIN
  COACH
  PLAYER
  PARENT
}

enum Tier {
  GRATIS
  PRO
  ELITE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// PlayerHQ-domenet (Fase 1.5)

enum SessionStatus {
  PLANNED
  ACTIVE
  COMPLETED
  SKIPPED
  CANCELLED
}

enum PyramidArea {
  FYS
  TEK
  SLAG
  SPILL
  TURN
}

enum LPhase {
  KROPP
  ARM
  KOLLE
  BALL
  AUTO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// ---------- Models ----------

model User {
  id          String    @id @default(cuid())
  // Knytter mot Supabase auth.users.id (UUID).
  // Holdes som String for å unngå Prisma-uuid-type-friksjon mot Supabase.
  authId      String    @unique
  email       String    @unique
  name        String
  phone       String?
  avatarUrl   String?
  role        UserRole  @default(PLAYER)
  tier        Tier      @default(GRATIS)
  lastLoginAt DateTime?
  // Spiller-profil (Fase 1.4)
  hcp          Float?
  playingYears Int?
  ambition     String?
  homeClub     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bookings        Booking[]
  parentRelations ParentRelation[] @relation("Child")
  childRelations  ParentRelation[] @relation("Parent")

  // PlayerHQ-relasjoner
  trainingPlans     TrainingPlan[]
  rounds            Round[]
  testResults       TestResult[]
  trackManSessions  TrackManSession[]
  subscription      Subscription?

  @@map("users")
}

// Foresatt-spiller relasjon (junior har ofte 1-2 foresatte; voksen kan ha 0)
model ParentRelation {
  id           String   @id @default(cuid())
  parentId     String
  childId      String
  relationship String   @default("Foresatt") // Foresatt, Trener, Søsken
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent User @relation("Parent", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("Child", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([childId])
  @@map("parent_relations")
}

model ServiceType {
  id          String   @id @default(cuid())
  name        String
  // Pris i ØRE (Int). Aldri Float for penger. Format i UI: priceOre / 100.
  priceOre    Int
  durationMin Int
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("service_types")
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@map("locations")
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  serviceTypeId String
  locationId    String
  startAt       DateTime
  endAt         DateTime
  status        BookingStatus @default(CONFIRMED)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])
  location    Location    @relation(fields: [locationId], references: [id])

  @@index([userId])
  @@index([startAt])
  @@map("bookings")
}

// ---------- PlayerHQ-modeller (Fase 1.5) ----------

model TrainingPlan {
  id          String    @id @default(cuid())
  userId      String
  name        String
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  // Coach-id (User med role=COACH) hvis plan opprettet av coach. Ikke FK i v1
  // for å holde det enkelt — modelleres som relasjon i Fase 1.9.
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions TrainingPlanSession[]

  @@index([userId, isActive])
  @@map("training_plans")
}

model TrainingPlanSession {
  id          String        @id @default(cuid())
  planId      String
  scheduledAt DateTime
  durationMin Int
  title       String
  rationale   String?
  pyramidArea PyramidArea
  status      SessionStatus @default(PLANNED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  plan   TrainingPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  drills SessionDrill[]
  log    TrainingPlanSessionLog?

  @@index([planId, scheduledAt])
  @@map("training_plan_sessions")
}

model ExerciseDefinition {
  id              String      @id @default(cuid())
  name            String
  description     String?
  videoUrl        String?
  pyramidArea     PyramidArea
  lPhase          LPhase
  defaultRepsSets String?
  csMin           Int?
  csMax           Int?
  createdAt       DateTime    @default(now())

  sessionDrills SessionDrill[]

  @@index([pyramidArea])
  @@map("exercise_definitions")
}

model SessionDrill {
  id         String  @id @default(cuid())
  sessionId  String
  exerciseId String
  repsSets   String
  csTarget   Int?
  notes      String?
  orderIndex Int     @default(0)

  session  TrainingPlanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise ExerciseDefinition  @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@map("session_drills")
}

model TrainingPlanSessionLog {
  id          String    @id @default(cuid())
  sessionId   String    @unique
  startedAt   DateTime
  completedAt DateTime?
  csAchieved  Int?
  notes       String?
  rating      Int? // 1-5
  createdAt   DateTime  @default(now())

  session TrainingPlanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("training_plan_session_logs")
}

// Mål-domenet

model CourseDefinition {
  id        String   @id @default(cuid())
  name      String
  par       Int
  rating    Float?
  slope     Int?
  createdAt DateTime @default(now())

  rounds Round[]

  @@map("course_definitions")
}

model Round {
  id       String   @id @default(cuid())
  userId   String
  courseId String
  playedAt DateTime
  score    Int
  sgTotal  Float?
  sgOtt    Float?
  sgApp    Float?
  sgArg    Float?
  sgPutt   Float?
  notes    String?
  createdAt DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course CourseDefinition @relation(fields: [courseId], references: [id])

  @@index([userId, playedAt])
  @@map("rounds")
}

model TestDefinition {
  id          String      @id @default(cuid())
  name        String
  description String?
  pyramidArea PyramidArea
  scoringRule String
  createdAt   DateTime    @default(now())

  results TestResult[]

  @@map("test_definitions")
}

model TestResult {
  id        String   @id @default(cuid())
  userId    String
  testId    String
  takenAt   DateTime
  score     Float
  notes     String?
  createdAt DateTime @default(now())

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  test TestDefinition @relation(fields: [testId], references: [id])

  @@index([userId, takenAt])
  @@map("test_results")
}

model TrackManSession {
  id         String   @id @default(cuid())
  userId     String
  recordedAt DateTime
  source     String // "csv-import" | "api"
  shotCount  Int      @default(0)
  rawJson    Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@map("trackman_sessions")
}

// Abonnement-domenet

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  tier                 Tier               @default(GRATIS)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
