model DrillMal {
  id                 String   @id @default(cuid())
  coachId            String
  navn               String
  beskrivelse        String?
  kategori           String
  pyramide           PyramidArea
  erFavoritt         Boolean  @default(false)
  erGlobal           Boolean  @default(false)
  bruktAntall        Int      @default(0)
  sistBrukt          DateTime?
  omraade            String?
  lFase              LFase?
  csNivaa            CSNivaa?
  miljo              MMiljo?
  prPress            PRPress?
  pPosisjoner        String[]
  componentFocus     String?
  fysTreningstype    String?
  fysMuskelgruppe    String?
  fysOvelse          String?
  fysSett            Int?
  fysReps            Int?
  fysVektProsent     Int?
  fysVarighetMin     Int?
  fysIntensitetsSone Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([coachId])
  @@index([pyramide])
  @@map("drill_maler")
}

model OktMal {
  id              String   @id @default(cuid())
  coachId         String
  navn            String
  beskrivelse     String?
  kategori        String
  pyramide        PyramidArea
  periodeType     PeriodeType?
  kategoriAK      String?
  erFavoritt      Boolean  @default(false)
  erGlobal        Boolean  @default(false)
  bruktAntall     Int      @default(0)
  sistBrukt       DateTime?
  durationMinutes Int
  practiceType    PracticeType
  notat           String?
  driller         OktMalDrill[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([coachId])
  @@index([pyramide])
  @@map("okt_maler")
}

model OktMalDrill {
  id              String  @id @default(cuid())
  malId           String
  mal             OktMal  @relation(fields: [malId], references: [id], onDelete: Cascade)
  sortOrder       Int
  pyramide        PyramidArea
  navn            String
  durationMinutes Int
  omraade         String?
  lFase           LFase?
  csNivaa         CSNivaa?

  @@index([malId])
  @@map("okt_mal_driller")
}
