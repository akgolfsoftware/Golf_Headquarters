// AK Golf HQ — Prisma schema
// Foundation: 4 startmodeller. Resten migreres inn i egen fase.
// Prisma 7: url/directUrl flyttet til prisma.config.ts. Schema har bare provider.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum UserRole {
  ADMIN
  COACH
  PLAYER
  PARENT
  GUEST
}

enum Tier {
  GRATIS
  PRO
  ELITE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// PlayerHQ-domenet (Fase 1.5)

enum SessionStatus {
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
  SKIPPED
  CANCELLED
}

// Status-enum for TrainingSessionV2. Holdes adskilt fra eldre SessionStatus
// for å unngå migrasjonskonflikt i eksisterende felter.
enum SessionStatusV2 {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  SKIPPED
}

// Påmeldingsstatus for TournamentEntry. Erstatter notes-prefiks-hack i
// withdrawFromTournament.
enum TournamentEntryStatus {
  PLANNED // meldt på
  CONFIRMED // bekreftet av spiller
  WITHDRAWN // trukket
  COMPLETED // gjennomført
  DNF // started, men trakk
}

enum PyramidArea {
  FYS
  TEK
  SLAG
  SPILL
  TURN
}

enum LPhase {
  GRUNN
  SPESIAL
  TURNERING
  // 8c.1 (Anders 2026-07-12): fire nye periodetyper på årsplan-tidslinja.
  TESTUKE
  FERIE
  TRENINGSSAMLING
  HELDAGSSAMLING
}

enum SkillArea {
  TEE_TOTAL
  TILNAERMING
  AROUND_GREEN
  PUTTING
  SPILL
}

enum SessionEnvironment {
  RANGE
  BANE
  STUDIO
  HJEM
  SIMULATOR
  GYM
}

// Kilde for en ExerciseDefinition — styrer hvem som eier og kan redigere
enum ExerciseSource {
  SYSTEM  // Seedet av AK Golf — ikke redigerbart av brukere
  COACH   // Opprettet av coach — synlig for coachens spillere
  PLAYER  // Opprettet av spiller — synlig for spiller + tildelt coach
}

// Synlighet for COACH/PLAYER-øvelser
enum ExerciseVisibility {
  PRIVATE        // Kun skaperen + tildelt coach
  COACH_PLAYERS  // Alle coachens spillere (kun for COACH-source)
}

// P14: spiller-status for permisjon, skade, retur til spill
enum UserStatus {
  AKTIV // Normal aktivitet
  PERMISJON // Pause (reise, jobb, etc.) — Subscription pauses
  SKADET // Skade — Subscription pauses, return-to-play-protokoll aktiveres
  INAKTIV // Lengre pause (> 6 mnd), historie beholdes
}

// P14: type permisjon/pause
enum LeaveReason {
  SKADE
  SYKDOM
  REISE
  JOBB
  STUDIER
  ANNET
}

// Treningstype — beskriver øvingsmetoden (blokkert / variabel / konkurranse / test).
enum DrillPracticeType {
  BLOKK // Isolert, repetitiv teknikk-innlæring
  VARIABEL // Varierende betingelser, tilpasnings-trening
  KONKURRANSE // Press-situasjon, scoring mot et krav
  SPILL_TEST // Spill-simulering eller benchmark-test
}

// Utstyr/anlegg-krav per drill — brukes for facility-matching mot spillerprofil.
// Tomme fasilitetKrav = drill kan gjøres overalt (ingen spesialkrav).
enum DrillFasilitet {
  RADAR // Launch monitor: TrackMan, FlightScope, Garmin R10, Mevo+
  MAT_NET // Innendørs matte + nett
  BUNKER // Tilgang til sandbunker
  KAMERA // iPhone + stativ for video-feedback
  PUTTING_GREEN_KORT // Putting green opptil 10m (kortspill)
  PUTTING_GREEN_LANG // Putting green 15m+ (lag-putt, 10m+ slag)
  SHORT_GAME_AREA // Nærspillsareal: gress, fra rough, chip/pitch
  DRIVING_RANGE // Utendørs driving range
  BANE // Tilgang til golfrunde (9 eller 18 hull)
  SIMULATOR // Innendørs simulator-bay
  VEKTSTANG // Benkpress, squat rack
  TRAPBAR // Hex bar / trapbar
  LOPEBANE // Friidrettsbane eller tredemølle
  MED_BALL // Medisinball (2-4 kg)
}

// NGF-kategori-skala for nivå-differensiering av drills og plan-templates.
// A = OWGR Top 150 (elite-profesjonell)
// B-D = nasjonalt elite-amateur til lavt proff
// E-G = scratch til HCP 5 (sterk amateur)
// H-J = HCP 5-15 (god klubbspiller)
// K-L = HCP 15+ / junior klubb-nivå
enum NgfKategori {
  A
  B
  C
  D
  E
  F
  G
  H
  I
  J
  K
  L
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// Program-tilhørighet for spillere.
// PLATFORM_ONLY = selvbetjent bruker uten coachrelasjon (GDPR-skille).
// Alle andre program = synlig i CoachHQ for tildelt coach.
enum PlayerProgram {
  WANG_TOPPIDRETT   // WANG Toppidrett Fredrikstad
  WANG_UNG          // WANG Ung Fredrikstad
  GFGK_MINI         // GFGK — Mini
  GFGK_BREDDE       // GFGK — Bredde/Utvikling
  GFGK_JENTER       // GFGK — Jenter
  GFGK_ELITE        // GFGK — Elite
  AK_ACADEMY        // AK Golf Academy (voksen individuell)
  AK_ACADEMY_JUNIOR // AK Golf Academy Junior
  PLATFORM_ONLY     // Selvbetjent — ingen coachrelasjon
}

enum PressureLevel {
  PR1
  PR2
  PR3
  PR4
  PR5
}

enum PlanStatus {
  DRAFT // Coach jobber på planen
  PENDING_PLAYER // Sendt til spiller for godkjenning
  ACCEPTED // Spiller har godtatt, klar til å starte
  REJECTED // Spiller ba om endring (se playerComment)
  ACTIVE // Pågående
  PAUSED // Midlertidig pause
  ARCHIVED // Ferdig eller avsluttet
}

// Treningsplanlegger (Masterplan Sesjon 0)

enum LFase {
  L_KROPP
  L_ARM
  L_KOLLE
  L_BALL
  L_AUTO
}

enum CSNivaa {
  CS50
  CS60
  CS70
  CS80
  CS90
  CS100
}

enum MMiljo {
  M0
  M1
  M2
  M3
  M4
  M5
}

enum PRPress {
  PR1
  PR2
  PR3
  PR4
  PR5
}

// Teknisk/Taktisk/Mentalt/Sosialt — eget klassifiseringsfelt på PositionTask
// (runde 2 · 2026-07-14), ved siden av pyramide-aksen. Anders: "Begge — legg
// til som eget felt". Nullable — aldri en sperre.
enum TaskKategori {
  TEKNISK
  TAKTISK
  MENTALT
  SOSIALT
}

// Rep-type per drill (bølge 2 · 2026-07-04). Låst av Anders — de fire volumtypene.
enum RepType {
  SVINGER_UTEN_BALL // antall svinger uten ball
  BALLER_SLATT // antall baller slått
  TID // minutter
  SETT_REPS // sett × reps
}

enum PracticeType {
  BLOKK
  RANDOM
  KONKURRANSE
  SPILL_TEST
}

enum PeriodeType {
  GRUNN
  SPESIALISERING
  TURNERING
  EVALUERING
  FERIE
}

// Workbench v2 — Sprint 1 enums

enum GoalCategory {
  OUTCOME // Resultatmål
  PROCESS // Prosessmål
}

enum SessionNoteType {
  SELF
  COACH_QUESTION
  VIDEO
}

enum SessionRequestStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

enum PlanAdjustmentStatus {
  PENDING
  APPROVED
  DECLINED
}

// ---------- Models ----------

model User {
  id                 String    @id @default(cuid())
  // Knytter mot Supabase auth.users.id (UUID).
  // Holdes som String for å unngå Prisma-uuid-type-friksjon mot Supabase.
  authId             String    @unique
  email              String    @unique
  name               String
  phone              String?
  avatarUrl          String?
  role               UserRole  @default(PLAYER)
  tier               Tier      @default(GRATIS)
  lastLoginAt        DateTime?
  // Spiller-profil (Fase 1.4)
  hcp                Float?
  playingYears       Int?
  ambition           String?
  homeClub           String?
  // VGS (videregående skole) — brukes for å koble spillere til toppidrettslinjer.
  school             String?
  // VG1 | VG2 | VG3 — klassetrinn for toppidrettselever. Redigeres av coach/admin.
  schoolYear         String?
  // Snittscore forrige sesong — brukes som baseline for fremgang.
  prevSeasonAvgScore Int?
  // Kanonisk kobling til turneringsidentitet (PublicPlayer) — settes automatisk
  // ved registrering via navn-matching. Gir spilleren turneringshistorikk i profilen.
  publicPlayerId     String?   @unique
  // Bruker-preferanser (notifikasjoner, språk, etc.) som flexibel JSON.
  // Strukturen håndheves i kode (src/lib/preferences.ts) ikke i DB.
  preferences        Json?

  // Tilgjengelige fasiliteter og utstyr (settes under onboarding/innstillinger).
  // Brukes for å filtrere drills slik at spilleren kun ser øvelser de kan gjøre.
  tilgjengeligeFasiliteter DrillFasilitet[] @default([])

  // GDPR soft-delete (P20). Bruker markeres som deletedAt = now() ved kontosletting.
  // Cron /api/cron/cleanup-deleted-accounts sletter permanent etter 30 dager.
  deletedAt DateTime?

  // GDPR art. 8 — mindreårig + foreldresamtykke (P17).
  // Norge: 16 år er aldersgrense for å samtykke selv til behandling av persondata.
  dateOfBirth             DateTime?
  requiresGuardianConsent Boolean   @default(false)
  guardianConsentGivenAt  DateTime?
  guardianConsentByUserId String?

  // P14: spiller-status (permisjon, skade, return-to-play)
  userStatus UserStatus @default(AKTIV)
  leaves     Leave[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings        Booking[]
  coachedBookings Booking[]        @relation("BookingCoach")
  calendarEvents  CalendarEvent[]
  parentRelations ParentRelation[] @relation("Child")
  childRelations  ParentRelation[] @relation("Parent")

  // PlayerHQ-relasjoner
  trainingPlans    TrainingPlan[]
  rounds           Round[]
  testResults      TestResult[]
  testSessions     TestSession[]
  testAssignments       TestAssignment[] @relation("PlayerTestAssignments")
  coachTestAssignments  TestAssignment[] @relation("CoachTestAssignments")
  trackManSessions TrackManSession[]
  subscription     Subscription?
  publicPlayer     PublicPlayer?     @relation(fields: [publicPlayerId], references: [id], onDelete: SetNull)

  // Coaching-relasjoner
  playerCoachingSessions CoachingSession[] @relation("PlayerCoachingSessions")
  coachCoachingSessions  CoachingSession[] @relation("CoachCoachingSessions")

  // Agent-relasjoner
  signals              Signal[]
  planActions          PlanAction[]
  coachedPlanActions   PlanAction[] @relation("PlanActionCoach")

  // Goals/achievements/sosiale (Fase 1.14)
  goals        Goal[]
  achievements Achievement[]
  friendshipsA Friendship[]  @relation("FriendshipUserA")
  friendshipsB Friendship[]  @relation("FriendshipUserB")

  // Documents og session-requests (Fase 1.17)
  documents               Document[]
  sessionRequestsAsPlayer SessionRequest[] @relation("SessionRequestUser")
  sessionRequestsAsCoach  SessionRequest[] @relation("SessionRequestCoach")

  // Workbench v2 — Sprint 1
  planAdjustmentsAsPlayer PlanAdjustment[]        @relation("PlanAdjustmentUser")
  planAdjustmentsAsCoach  PlanAdjustment[]        @relation("PlanAdjustmentCoach")
  planChangeRequestsAsPlayer PlanChangeRequest[]  @relation("PlanChangePlayer")
  planChangeRequestsAsCoach  PlanChangeRequest[]  @relation("PlanChangeCoach")
  tournamentPreparations  TournamentPreparation[]

  // CoachHQ-relasjoner (Fase 2.1)
  tournamentResults TournamentResult[]
  coachedGroups     Group[]                   @relation("CoachOfGroup")
  groupMemberships  GroupMember[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  coachAvailability CoachAvailability[]
  serviceTypes      ServiceType[]             @relation("CoachServiceTypes")
  googleCalendar    GoogleCalendarConnection?

  // WAGR-snapshot (om spilleren er registrert i World Amateur Golf Ranking)
  wagrSnapshot WagrSnapshot?

  // Stripe-betalinger (Payment-modell)
  payments Payment[]

  // AI-genererte planer (Spor 2)
  aiGenerationsAsUser  AiPlanGeneration[] @relation("AiGenUser")
  aiGenerationsAsCoach AiPlanGeneration[] @relation("AiGenCoach")

  // Foreldreportal — invitasjoner (Spor 3)
  playerInvitations   ParentInvitation[] @relation("PlayerInvitations")
  acceptedInvitations ParentInvitation[] @relation("AcceptedInvitations")

  // In-app varsler
  notifications Notification[]

  // Sesongplanlegger (Fase 1.18)
  seasonPlans       SeasonPlan[]
  tournamentEntries TournamentEntry[]

  // Manuelt-opprettede turneringer (Stats Fase 1)
  createdTournaments Tournament[] @relation("ManualTournamentCreator")

  // Stats Fase 4 — SG-sammenligning
  sgInputs          BrukerSgInput[]
  sgSammenligninger BrukerSammenligning[]

  // Coaching-videoer (Sprint M11b)
  videosAsPlayer SessionVideo[] @relation("VideoPlayer")
  videosAsCoach  SessionVideo[] @relation("VideoCoach")

  // Spiller-opplastede swing-videoer (F3 scaffold)
  playerSwingVideos PlayerSwingVideo[]

  // Drill-challenges (M14)
  ownedChallenges         DrillChallenge[]       @relation("ChallengeOwner")
  challengeParticipations ChallengeParticipant[]

  // Equipment bag (M18)
  equipmentBag EquipmentBag?

  // Helse-logg (H1) — daglige målinger, én rad per dato
  healthEntries HealthEntry[]

  // Talent-modul (M13) — kun for spillere i talent-tracking
  talentTracking TalentTracking?

  // Drill-opprettelse (taxonomy v4)
  createdExercises ExerciseDefinition[] @relation("ExerciseCreator")
  coachDirektiverGitt    CoachDrillDirectiv[] @relation("DirektivCoach")
  coachDirektiverMottatt CoachDrillDirectiv[] @relation("DirektivSpiller")

  // Voice-memo-opptak (Sprint recording V1)
  uploadedRecordings SessionRecording[] @relation("UploadedRecordings")
  playerRecordings   SessionRecording[] @relation("PlayerRecordings")

  // Caddie chat-meldinger (intern AI-assistent for admin)
  caddieMessages CaddieMessage[]

  // SG Coaching Hub (Phase 1)
  sgInsights     SgInsight[]
  bestSessionRef BestSessionReference?

  // Teknisk utviklingsplan
  technicalPlans      TechnicalPlan[]      @relation("TechPlanUser")
  createdTechPlans    TechnicalPlan[]      @relation("TechPlanCreator")
  techPlanAudits      TechnicalPlanAudit[]
  techPlanSuggestions PlanSuggestion[]     @relation("SuggestionDecider")

  // Treningssamlinger (Workbench Plan A · Sprint 3)
  trainingCamps       TrainingCamp[]

  // Fasilitet-preferanser (Workbench Plan A · Sprint 5)
  facilityPrefs       FacilityPrefs?

  // Plan-sessions (Workbench Plan A · Sprint 6)
  planSessions        PlanSession[]

  // Fysisk plan (per plan Del 31)
  fysiskeOktRelasjoner FysiskPlan[] @relation("FysiskPlanUser")
  lagdeFysPlaner       FysiskPlan[] @relation("FysiskPlanCreator")

  // Plan-templates (AI-baseline-system)
  createdPlanTemplates  PlanTemplate[]      @relation("PlanTemplateCoach")
  approvedPlanTemplates PlanTemplate[]      @relation("PlanTemplateApprover")
  planEffectiveness     PlanEffectiveness[]

  // Notion-sync (v1.1) — per-user OAuth-tilkobling til Notion
  notionConnection NotionConnection?

  // Program-enrolleringer (mange-til-mange via PlayerEnrollment).
  // Som spiller: hvilke program spilleren er/har vært i.
  // Som coach: hvilke spillere er tildelt meg.
  enrollmentsAsPlayer PlayerEnrollment[] @relation("PlayerEnrollments")
  enrollmentsAsCoach  PlayerEnrollment[] @relation("CoachEnrollments")

  // Web Push-subscriptions — én rad per enhet/browser.
  pushSubscriptions PushSubscription[]

  // Trene sammen-feature — delte økter med spiller-kompiser
  hostedSessions        TrainingSessionV2[]  @relation("SessionHost")
  sessionParticipations SessionParticipant[]

  // Coach-notater — privat notat-system om spillere
  coachNotesAuthored CoachNote[] @relation("CoachNoteCoach")
  coachNotesAbout    CoachNote[] @relation("CoachNotePlayer")

  // Egen-test — TestDefinition opprettet av spiller
  customTests TestDefinition[] @relation("TestCreator")

  // Fri trenings-logg (volum per SG-område) — mater korrelasjon + training-gap-agent
  trainingLogs TrainingLog[]

  // Performance: hot path — filtrere aktive spillere/coacher
  // (PlayerHQ-lister, CoachHQ-portefølje, talent-tracking).
  @@index([role, deletedAt])
  @@map("users")
}

// Web Push-abonnement per enhet/browser. Én bruker kan ha flere
// (laptop, telefon, ulike browsere). Slettes når subscription returnerer
// 410 Gone fra push-service (gammel/avregistrert).
model PushSubscription {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// Talent-tracking for spillere i akademiets talent-program.
// Én rad per spiller. Radar-akser 1-10 representerer Caddies/coachens
// kvalitative vurdering på 5 dimensjoner.
model TalentTracking {
  id           String   @id @default(cuid())
  userId       String   @unique
  // Aldersnivå: U10, U12, U14, U16, U18, Senior
  niva         String
  // Klubb (kan være null hvis ikke registrert klubb)
  klubb        String?
  // Region: Oslo, Østfold, Vestfold, Hordaland, Trøndelag etc.
  region       String?
  // Når talent ble inkludert i program
  inkludertFra DateTime @default(now())
  // Radar-akser (1-10)
  fysisk       Int?
  teknikk      Int?
  taktikk      Int?
  mental       Int?
  motivasjon   Int?
  // Milepæler som JSON-array: [{ tittel, dato, beskrivelse }, ...]
  milepaeler   Json?
  notater      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([niva, region])
  @@index([klubb])
  @@map("talent_tracking")
}

// Ressurs-bibliotek for talent-program. Videoer, artikler, podcasts.
model TalentRessurs {
  id          String   @id @default(cuid())
  tittel      String
  kategori    String // video | artikkel | podcast
  url         String
  // Hvilket nivå er ressursen mest relevant for
  niva        String? // U10, U12, ..., Senior, null = alle
  // Fokus-tag: teknikk, mental, taktikk, fysisk, motivasjon
  fokus       String?
  // Beskrivelse / sammendrag
  beskrivelse String?
  createdAt   DateTime @default(now())

  @@index([kategori, niva])
  @@index([fokus])
  @@map("talent_ressurser")
}

// Manuell helse-logg. Én rad per (userId, date). Foreløpig kilde for
// trenings-belastnings-justering; Apple Health/Garmin-import kommer i v2.
model HealthEntry {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  restingHr  Int?
  hrv        Int? // HRV (RMSSD, ms) — manuelt logget, som hvilepuls. Wearable-sync kan fylle samme felt.
  sleepHours Float?
  weightKg   Float?
  notes      String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("health_entries")
}

// P14: Permisjon/skade (Leave) per spiller.
// Når en Leave er aktiv (endAt null eller > now), Subscription pauses.
// Coach varsles ved opprettelse og return-to-play-modal aktiveres.
model Leave {
  id            String      @id @default(cuid())
  userId        String
  reason        LeaveReason
  startAt       DateTime
  endAt         DateTime? // null = pågående (åpen-ende permisjon)
  description   String?     @db.Text
  // Hvis SKADE: rehab-protokoll og return-to-play-status
  isInjury      Boolean     @default(false)
  rehabPlan     Json? // strukturert rehab-plan
  returnedAt    DateTime?
  notifiedCoach Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
  @@index([userId, endAt])
  @@map("leaves")
}

// Foreldre-invitasjons-relasjon (V2 Spor 3).
// Brukes for typing av invitasjonen + (valgfritt) som metadata på ParentRelation.
enum ParentLinkRelation {
  FATHER
  MOTHER
  GUARDIAN
}

// En spillers invitasjon til en foresatt. Token-basert, utløper etter 7 dager.
// Når invitasjonen aksepteres opprettes en PARENT-User + ParentRelation
// mellom forelder og barn, og acceptedAt/acceptedById settes her.
model ParentInvitation {
  id           String             @id @default(cuid())
  token        String             @unique @default(cuid())
  playerId     String
  email        String
  relation     ParentLinkRelation @default(GUARDIAN)
  expiresAt    DateTime
  acceptedAt   DateTime?
  acceptedById String?
  createdAt    DateTime           @default(now())

  player     User  @relation("PlayerInvitations", fields: [playerId], references: [id], onDelete: Cascade)
  acceptedBy User? @relation("AcceptedInvitations", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([playerId])
  @@index([email])
  @@map("parent_invitations")
}

// Foresatt-spiller relasjon (junior har ofte 1-2 foresatte; voksen kan ha 0)
model ParentRelation {
  id           String   @id @default(cuid())
  parentId     String
  childId      String
  relationship String   @default("Foresatt") // Foresatt, Trener, Søsken
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent User @relation("Parent", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("Child", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([childId])
  @@map("parent_relations")
}

model ServiceType {
  id          String   @id @default(cuid())
  // Public slug for booking-URL (/booking/[slug])
  slug        String   @unique
  name        String
  // Pris i ØRE (Int). Aldri Float for penger. Format i UI: priceOre / 100.
  priceOre    Int
  durationMin Int
  description String?
  active      Boolean  @default(true)
  // Coach som tilbyr tjenesten. Null = felles (gruppe, WANG).
  // Erstatter slug-prefiks-konvensjonen i UI med ekte DB-relasjon.
  coachUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]
  coach    User?     @relation("CoachServiceTypes", fields: [coachUserId], references: [id], onDelete: SetNull)

  @@index([coachUserId])
  @@map("service_types")
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String
  latitude  Float?
  longitude Float?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings          Booking[]
  facilities        Facility[]
  coachAvailability CoachAvailability[]

  @@map("locations")
}

model Booking {
  id                      String        @id @default(cuid())
  userId                  String?
  serviceTypeId           String
  locationId              String
  startAt                 DateTime
  endAt                   DateTime
  status                  BookingStatus @default(PENDING)
  notes                   String?
  // Pris låst ved booking (i øre, ikke Float). Refusjonsbeløp baseres på dette.
  // For credit-baserte bookinger fra Academy-abonnement: priceOre = 0.
  priceOre                Int           @default(0)
  // Stripe-tracking. CheckoutSession før betaling, PaymentIntent etter.
  // Null for credit-baserte abonnement-bookinger.
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  // Hvis booking er trukket fra Academy-abonnement, peker dette tilbake til
  // Subscription. Brukes for credit-tilbakeføring ved avbestilling >24t.
  subscriptionId          String?
  // Google Calendar event-ID hvis booking er pushet til coachens kalender.
  // Brukes til oppdater/slett ved endring/avbestilling. Null hvis Calendar
  // ikke er koblet, eller hvis push feilet (best-effort sync).
  googleEventId           String?
  // Hvilken fasilitet (rom/range/simulator) bookingen tar opp. Optional —
  // ikke alle bookinger er koblet til en spesifikk fasilitet (drop-in kan
  // være "et sted på lokasjonen"). Brukes for tetthet-visning i kalender.
  facilityId              String?
  // Kontakt-info for bookinger gjort av ikke-innloggede kunder (gjest-flow).
  guestName               String?
  guestEmail              String?
  guestPhone              String?
  // Denormalisert fra serviceType.coachUserId for ytelse og unik-indeks.
  // Settes automatisk ved opprettelse og oppdateres ved koach-bytte.
  // ON DELETE SET NULL — booking beholdes i historikk hvis coach slettes.
  // S-12: brukes i partial unique index som hindrer dobbel-booking på DB-nivå.
  coachId                 String?
  // Sletting av brukerkonto skal ikke slette historiske bookinger — sett userId til null.
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  // Live-økt: settes når coach trykker «Start økt» — kobler bookingen til den
  // opprettede TrainingSessionV2 (live-konsoll). Plain id (ingen relasjon — isolert).
  trainingSessionV2Id     String?

  user         User?              @relation(fields: [userId], references: [id])
  coach        User?              @relation("BookingCoach", fields: [coachId], references: [id], onDelete: SetNull)
  serviceType  ServiceType        @relation(fields: [serviceTypeId], references: [id])
  location     Location           @relation(fields: [locationId], references: [id])
  subscription Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  facility     Facility?          @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  payments     Payment[]
  recordings   SessionRecording[]

  @@index([userId])
  @@index([coachId])
  @@index([startAt])
  @@index([stripeCheckoutSessionId])
  @@index([subscriptionId])
  @@index([facilityId])
  // Performance: hot path — kalender-queries filtrerer på status + tidsvindu
  // (booking.akgolf.no kalender, kapasitet-graf, admin/bookinger).
  @@index([startAt, status])
  // Dobbeltbooking-vern (A-pakken 2026-07-13): EXCLUSION-constraintet
  // booking_coach_no_overlap i Postgres (btree_gist + tsrange) avviser
  // OVERLAPPENDE ikke-avlyste bookinger per coach — sterkere enn den gamle
  // eksakt-likhet-@@unique (droppet). Prisma kan ikke uttrykke EXCLUSION,
  // så vernet lever i DB + lib/booking/kollisjonsvern.ts (fasilitets-
  // kapasitet håndteres der med advisory-lås + telling).
  @@map("bookings")
}

// I3 (Bølge 1 — interaksjonsgrunnmur): kalenderhendelse som blokkerer
// booking i et tidsrom (ferie, stengt anlegg, møte). coachId=null er
// reservert for «hele akademiet», men UI-et setter i dag alltid til den
// innloggede coachen — se src/lib/booking/availability.ts for konflikt-
// sjekken og src/lib/kalender-hendelse/actions.ts for opprett/slett.
model CalendarEvent {
  id        String   @id @default(cuid())
  coachId   String?
  title     String
  startAt   DateTime
  endAt     DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach User? @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([startAt, endAt])
  @@map("calendar_events")
}

// ---------- PlayerHQ-modeller (Fase 1.5) ----------

model TrainingPlan {
  id            String     @id @default(cuid())
  userId        String
  name          String
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean    @default(true)
  // Status-enum for godkjennings-flyt mellom coach og spiller.
  // DRAFT → PENDING_PLAYER → ACCEPTED → ACTIVE → ARCHIVED.
  // REJECTED hvis spiller ber om endring (se playerComment).
  status        PlanStatus @default(DRAFT)
  // WB4: snapshot av øktene ved forrige publisering (diff-grunnlag).
  // JSON — zod-valideres ved lesing (publish-actions).
  publishedSnapshot Json?
  // Kommentar fra spiller ved REJECTED.
  playerComment String?
  // Coach-id (User med role=COACH) hvis plan opprettet av coach. Ikke FK i v1
  // for å holde det enkelt — modelleres som relasjon i Fase 1.9.
  createdById   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // AI-generering (Spor 2). aiGenerated=true når plan er opprettet fra
  // AiPlanGeneration. aiGenerationId peker til kilde-genereringen.
  aiGenerated    Boolean @default(false)
  aiPrompt       String?
  aiModel        String?
  aiGenerationId String?

  // Mål-allokering (pyramide-%, { FYS, TEK, SLAG, SPILL, TURN }). Settes når en
  // coach godkjenner et PYRAMID_ADJUST-forslag; agentene måler mot DENNE i
  // stedet for standard-målet. null = bruk STANDARD_MAL. Valideres med zod.
  targetAllocation Json?

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions      TrainingPlanSession[]
  planActions   PlanAction[]
  aiGeneration  AiPlanGeneration?     @relation(fields: [aiGenerationId], references: [id])
  effectiveness PlanEffectiveness?

  @@index([userId, isActive])
  @@index([status])
  @@index([aiGenerationId])
  @@map("training_plans")
}

// AI-generert plan-forslag (Spor 2). Hver kall til AI-coachen for å lage en
// treningsplan logges her — kontekst, prompt, respons, tokens og kost.
// Revisjoner peker tilbake til opprinnelig via iterationOf.
model AiPlanGeneration {
  id           String   @id @default(cuid())
  userId       String
  coachId      String
  prompt       String
  systemPrompt String
  contextJson  Json
  responseJson Json
  model        String
  tokensInput  Int?
  tokensOutput Int?
  costUsd      Float?
  iterationOf  String?
  createdAt    DateTime @default(now())

  user            User               @relation("AiGenUser", fields: [userId], references: [id], onDelete: Cascade)
  coach           User               @relation("AiGenCoach", fields: [coachId], references: [id], onDelete: Cascade)
  trainingPlans   TrainingPlan[]
  iterations      AiPlanGeneration[] @relation("AiPlanIterations")
  parentIteration AiPlanGeneration?  @relation("AiPlanIterations", fields: [iterationOf], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([coachId, createdAt])
  @@index([iterationOf])
  @@map("ai_plan_generations")
}

model TrainingPlanSession {
  id            String              @id @default(cuid())
  planId        String
  scheduledAt   DateTime
  durationMin   Int
  title         String
  rationale     String?
  pyramidArea   PyramidArea
  skillArea     SkillArea?
  environment   SessionEnvironment?
  lPhase        LPhase?
  pressureLevel PressureLevel?
  // AK-formel (Fase 0 · 2026-06-30) — metodikk-dimensjonene, speiler TrainingSessionV2.
  // pyramidArea + pressureLevel (over) er to av seks AK-akser; disse fire er resten.
  lFase         LFase?
  miljo         MMiljo?
  csNivaa       CSNivaa?
  pPosisjoner   String[]
  status        SessionStatus       @default(PLANNED)
  liveSnapshot  Json? // Løpende live-fremdrift (reps/tid per drill). Nulles ved completeSession.
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  plan           TrainingPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  drills         SessionDrill[]
  log            TrainingPlanSessionLog?
  clubsPracticed ClubsPracticed[]

  @@index([planId, scheduledAt])
  @@map("training_plan_sessions")
}

model ExerciseDefinition {
  id              String      @id @default(cuid())
  name            String
  description     String?
  videoUrl        String?
  pyramidArea     PyramidArea
  lPhase          LPhase?
  defaultRepsSets String?
  csMin           Int?
  csMax           Int?
  durationMin     Int?
  createdBy       String?
  parametersJson  Json?

  // Nivå-differensiering (NGF-skala + HCP-range)
  skillArea   SkillArea?
  minKategori NgfKategori?
  maxKategori NgfKategori?
  minHcp      Float?
  maxHcp      Float?

  // Kontekst — hvor og hvordan drillen kjøres
  environment SessionEnvironment[] @default([])
  utstyr      String[]             @default([])
  intensitet  Int? // 1-10
  lPhases     LPhase[]             @default([])
  morad       Boolean              @default(false)

  // Fasilitets-krav: strukturerte utstyr/anlegg-krav for facility-matching.
  // Tom liste = drill har ingen spesialkrav (kan gjøres av alle).
  fasilitetKrav DrillFasilitet[] @default([])

  // Pedagogikk
  prerequisites String[] @default([])
  tags          String[] @default([])
  coachNotes    String?
  kilde         String?

  // Treningstype — øvingsmetode
  treningstype DrillPracticeType?

  // Progresjon
  defaultSets        Int?
  defaultReps        Int?
  csTargetByKategori Json? // {A:95,B:90,...} per NGF-kategori

  // Egendefinerte øvelser (COACH/PLAYER-source)
  source       ExerciseSource      @default(SYSTEM)
  visibility   ExerciseVisibility  @default(PRIVATE)
  imageUrl     String?             @map("image_url") // Supabase Storage URL for bilde/screenshot
  muscleGroups String[]            @default([]) @map("muscle_groups") // ["glutes","hamstrings",...]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUser  User?          @relation("ExerciseCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  sessionDrills  SessionDrill[]
  coachDirektiver CoachDrillDirectiv[]
  fysOvelseRader FysOvelseRad[]

  @@index([pyramidArea])
  @@index([skillArea])
  @@index([minKategori, maxKategori])
  @@index([source, createdBy])
  @@map("exercise_definitions")
}

model SessionDrill {
  id         String  @id @default(cuid())
  sessionId  String
  exerciseId String
  repsSets   String
  sets       Int?
  reps       Int?
  csTarget   Int?
  // AK-formel per drill (Del B · 2026-06-30) — speiler drill-nivå-typene på TrainingDrillV2.
  // Arver øktas (TrainingPlanSession) default når null; kan overstyres per drill.
  lFase       LFase?
  miljo       MMiljo?
  csNivaa     CSNivaa?
  prPress     PRPress?
  // Alle-seks-per-drill (bølge 2 · 2026-07-04) — pyramide + område per drill (arver økta når null).
  pyramidArea PyramidArea?
  skillArea   SkillArea?
  // Rep-type + volum per drill (bølge 2). repType velger hvilke volumfelt som gjelder.
  repType     RepType?
  repAntall   Int? // antall svinger (SVINGER_UTEN_BALL) eller baller (BALLER_SLATT)
  repMinutter Int? // minutter (TID)
  repSett     Int? // sett (SETT_REPS)
  repReps     Int? // reps per sett (SETT_REPS)
  pPosisjoner String[]
  notes      String?
  orderIndex Int     @default(0)
  // Kobling til teknisk-plan-oppgave (runde 2 · 2026-07-14) — når satt,
  // logges reps for denne drillen automatisk mot oppgaven ved fullføring.
  positionTaskId String?

  session      TrainingPlanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise     ExerciseDefinition  @relation(fields: [exerciseId], references: [id])
  positionTask PositionTask?       @relation(fields: [positionTaskId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([positionTaskId])
  @@map("session_drills")
}

// Plan-templates: kodifisert coach-erfaring per (NGF-kategori × lPhase).
// AI bruker disse som baseline og justerer basert på spillerens SG-data,
// pyramide-balanse og mål. ~15-20 templates totalt (5 kategorier × 3 faser).
model PlanTemplate {
  id                String      @id @default(cuid())
  name              String // "A1 Konkurranse-fase Standard"
  description       String?
  kategori          NgfKategori
  lPhase            LPhase
  varighetUker      Int         @default(4)
  ukentligOktAntall Int         @default(5)

  // Disciplin-fordeling som JSON: {FYS: 0.15, TEK: 0.25, SLAG: 0.25, SPILL: 0.2, TURN: 0.15}
  disciplinFordeling Json

  // Mål-aldersgruppe (optional — null = alle aldre)
  minAlder Int?
  maxAlder Int?

  // Metadata
  byCoachId        String?
  approved         Boolean   @default(false)
  approvedById     String?
  approvedAt       DateTime?
  usageCount       Int       @default(0)
  effectivenessAvg Float? // gjennomsnitt fra PlanEffectiveness

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  byCoach       User?                 @relation("PlanTemplateCoach", fields: [byCoachId], references: [id], onDelete: SetNull)
  approvedBy    User?                 @relation("PlanTemplateApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  sessions      PlanTemplateSession[]
  effectiveness PlanEffectiveness[]

  @@unique([kategori, lPhase, name])
  @@index([kategori, lPhase])
  @@map("plan_templates")
}

model PlanTemplateSession {
  id          String             @id @default(cuid())
  templateId  String
  ukeNr       Int // 1-N (N = varighetUker)
  dagNr       Int // 1-7 (mandag=1)
  title       String
  varighetMin Int
  pyramidArea PyramidArea
  skillArea   SkillArea?
  environment SessionEnvironment
  // Anbefalte drill-IDer + sets/reps/csTarget per drill
  // Format: [{exerciseId, sets, reps, csTarget, notes}]
  drillsJson  Json
  focus       String?
  notes       String?

  template PlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, ukeNr, dagNr])
  @@index([templateId])
  @@map("plan_template_sessions")
}

// Effektivitets-tracking — etter fullført TrainingPlan: pre/post SG-deltas
// + completion-rate. AI bruker dette til å lære hvilke templates som virker.
model PlanEffectiveness {
  id         String  @id @default(cuid())
  planId     String  @unique
  templateId String? // hvilken template ble brukt som baseline
  userId     String

  // Pre/post snapshots
  preSnapshot  Json // {sgTotal, sgOTT, sgAPP, sgARG, sgPUTT, hcp, kategori}
  postSnapshot Json // samme felter etter plan

  // Beregnet effekt
  sgTotalDelta Float?
  sgOttDelta   Float?
  sgAppDelta   Float?
  sgArgDelta   Float?
  sgPuttDelta  Float?
  hcpDelta     Float?

  completionRate Float // 0-1 — andel økter fullført
  selfRating     Float? // 1-5 spillerens egen vurdering
  coachRating    Float? // 1-5 coachens vurdering

  notes String? // coach-notater om hva som virket / ikke virket

  computedAt DateTime @default(now())

  plan     TrainingPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  template PlanTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@map("plan_effectiveness")
}

model TrainingPlanSessionLog {
  id                String    @id @default(cuid())
  sessionId         String    @unique
  startedAt         DateTime
  completedAt       DateTime?
  csAchieved        Int?
  notes             String? // Spillerens egne notater fra live-økt
  rating            Int? // 1-5, spillerens mood/rating
  totalReps         Int? // Sum faktiske reps logget i økta (frosset ved fullføring)
  drillAggregates   Json? // Per-drill aggregat: reps, elapsedSec, CS/M/PR, notat (frosset ved fullføring)
  abandonReason     String? // Valgfri årsak når økta ble forlatt (ABANDONED)
  coachFeedback     String? // Coachens tilbakemelding på fullført økt
  coachFeedbackAt   DateTime?
  coachFeedbackById String?
  createdAt         DateTime  @default(now())

  session TrainingPlanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("training_plan_session_logs")
}

// Mål-domenet

model CourseDefinition {
  id        String   @id @default(cuid())
  name      String
  par       Int
  rating    Float?
  slope     Int?
  createdAt DateTime @default(now())

  // Bro til banegeometri (baneguide) — valgfri kobling til Bane med hull-kart
  baneId    String?

  rounds      Round[]
  tournaments Tournament[]
  bane        Bane?        @relation(fields: [baneId], references: [id], onDelete: SetNull)

  @@index([baneId])
  @@map("course_definitions")
}

// Fri trenings-logg: spiller logger treningstid per SG-område (ad-hoc, utenfor plan).
// Mater korrelasjonsanalyse (volum vs SG neste uke) og training-gap-agenten.
model TrainingLog {
  id        String     @id @default(cuid())
  userId    String
  date      DateTime   @db.Date
  sgArea    SgCategory
  minutes   Int
  drillName String?
  quality   Int?       @db.SmallInt // 1-5
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, sgArea])
  @@map("training_logs")
}

model Round {
  id           String   @id @default(cuid())
  userId       String
  courseId     String
  playedAt     DateTime
  score        Int
  sgTotal      Float?
  sgOtt        Float?
  sgApp        Float?
  sgArg        Float?
  sgPutt       Float?
  // Granulære SG-felter (fra taksonomien — alle valgfrie)
  sgTee        Float?
  sgApp200     Float?
  sgApp150     Float?
  sgApp100     Float?
  sgApp50      Float?
  sgChip       Float?
  sgPitch      Float?
  sgLob        Float?
  sgBunker     Float?
  sgPutt0_3    Float?
  sgPutt3_5    Float?
  sgPutt5_10   Float?
  sgPutt10_15  Float?
  sgPutt15_25  Float?
  sgPutt25_40  Float?
  sgPutt40plus Float?
  // 'manual' = håndtastet (overskrives ALDRI av beregning) | 'beregnet' = fra slag-kjeden
  sgSource     String?
  // 'turnering' | 'trening' — null = ukjent (eksisterende runder forblir umerket)
  roundType    String?
  notes        String?
  createdAt    DateTime @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     CourseDefinition @relation(fields: [courseId], references: [id])
  shots      Shot[]
  holeScores HoleScore[]

  @@index([userId, playedAt])
  @@map("rounds")
}

// Per-slag statistikk (manuell wizard eller UpGame-import)

enum ShotLie {
  TEE
  FAIRWAY
  SEMI_ROUGH
  ROUGH
  DEEP_ROUGH
  BUNKER
  GREEN
  WATER
  OOB
  TREES
}

enum WindDir {
  STILLE
  MEDVIND
  MOTVIND
  VENSTRE
  HOYRE
}

enum ShotType {
  DRIVE
  APPROACH
  CHIP
  PITCH
  PUTT
  BUNKER
  RECOVERY
  DROP
}

model Shot {
  id            String   @id @default(cuid())
  roundId       String
  holeNumber    Int
  holePar       Int
  shotNumber    Int
  club          String?
  lie           ShotLie
  distanceToPin Float?
  distanceHit   Float?
  windDir       WindDir?
  shotType      ShotType
  isPenalty     Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())

  // For shot-map og runde-statistikk (GPS: X=lng, Y=lat — lib/baneguide/shot-coords.ts)
  startX        Float?
  startY        Float?
  endX          Float?
  endY          Float?
  // Valgfri siktelinje (UpGame-mønsteret): dispersjon måles mot intensjon når satt
  targetX       Float?
  targetY       Float?
  mentalScore   Int?     @db.SmallInt // 1-5

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, holeNumber, shotNumber])
  @@index([roundId, holeNumber])
  @@map("shots")
}

// Persistert live-tapper: baller per kølle per plan-økt (skrives debounced fra
// tapper-flaten). Plain planSessionId uten @relation — additivt og isolert,
// samme mønster som trainingSessionV2Id på Booking.
model SessionBallLog {
  id            String   @id @default(cuid())
  planSessionId String
  club          String
  count         Int      @default(0)
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([planSessionId, club])
  @@index([planSessionId])
  @@map("session_ball_logs")
}

model HoleScore {
  id         String   @id @default(cuid())
  roundId    String
  holeNumber Int
  par        Int
  strokes    Int
  putts      Int?
  fairway    Boolean?
  gir        Boolean?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, holeNumber])
  @@index([roundId])
  @@map("hole_scores")
}

model TestDefinition {
  id          String      @id @default(cuid())
  name        String
  description String?
  pyramidArea PyramidArea
  scoringRule String
  protocol    Json?
  createdAt   DateTime    @default(now())

  // Egen-test-feature: spillere kan lage egne tester
  createdById     String?
  createdBy       User?           @relation("TestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  isCustom        Boolean         @default(false)
  visibility      TestVisibility  @default(PRIVATE)
  isCoachApproved Boolean         @default(false)
  approvedAt      DateTime?
  updatedAt       DateTime        @default(now()) @updatedAt

  results  TestResult[]
  sessions TestSession[]
  assignments TestAssignment[]

  @@index([createdById, isCustom])
  @@index([visibility, isCustom])
  @@map("test_definitions")
}

enum TestVisibility {
  PRIVATE   // kun for skaperen
  COACH     // delt med min coach
  GROUP     // delt med min gruppe
  ACADEMY   // delt med hele akademi
}

model TestResult {
  id        String   @id @default(cuid())
  userId    String
  testId    String
  takenAt   DateTime
  score     Float
  notes     String?
  details   Json?
  createdAt DateTime @default(now())

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  test TestDefinition @relation(fields: [testId], references: [id])

  @@index([userId, takenAt])
  @@map("test_results")
}

/// In-progress test-økt (live scoring). Opprettes ved `start`, oppdateres per slag,
/// committes til TestResult ved `complete`. Slettes ved `abort`.
enum TestSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABORTED
}

model TestSession {
  id               String            @id @default(cuid())
  userId           String
  testId           String
  status           TestSessionStatus @default(IN_PROGRESS)
  // Hvilket steg spilleren er på (0-indexed mot protokoll.steps[])
  currentStepIndex Int               @default(0)
  // Akkumulert data per steg: { [stepId]: ShotData[] }
  scoringData      Json              @default("{}")
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  abortedAt        DateTime?
  // Når committed: peker på resulterende TestResult
  testResultId     String?

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  test TestDefinition @relation(fields: [testId], references: [id])

  @@index([userId, status])
  @@index([testId, status])
  @@map("test_sessions")
}

/// Tildeling av en test fra coach til spiller. Spiller varsles ved opprettelse;
/// coach varsles når spilleren fullfører (resultatet kobles via completedResultId).
enum TestAssignmentStatus {
  OPEN
  COMPLETED
