<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Mulligan e-post-triage — kjører hver hele time kl. 08:00–20:00 (13 kjøringer/dag).
  Antakelse, ikke bekreftet: juster StartCalendarInterval mot Mulligans
  faktiske åpningstider og faktisk ønsket kjørefrekvens (kan f.eks. droppes
  til hver 2. time hvis 13x/dag er unødvendig hyppig for volumet).

  Installasjon (Mac Mini):
    1. Juster stien under WorkingDirectory til repoets plassering.
    2. cp com.akgolf.mulligan-triage.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.akgolf.mulligan-triage.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.akgolf.mulligan-triage</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/npm</string>
    <string>run</string>
    <string>mulligan:triage</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/anderskristiansen/Developer/Golf_Headquarters</string>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>10</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>11</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>12</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>13</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>14</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>15</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>StandardOutPath</key>
  <string>/tmp/mulligan-triage.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/mulligan-triage.err</string>
</dict>
</plist>
