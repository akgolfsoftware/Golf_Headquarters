/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# generert output fra scripts (f.eks. Mac-indekseringsjobben)
scripts/*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Prisma generated client
/src/generated

# vercel
.vercel

