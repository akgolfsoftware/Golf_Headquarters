# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Genererte design-kobling-tabeller (store base64-HTML, regenereres via scripts/kobling-*.mjs)
docs/kobling-godkjenning/*.html

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# generert output fra scripts (f.eks. Mac-indekseringsjobben)
scripts/*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Prisma generated client
/src/generated

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
ruvector.db
.claude/scheduled_tasks.lock
agentdb.rvf*

# Serwist-generert service worker (bygges ved next build)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
.worktrees/
.superpowers/
.claude/worktrees/

# Arkiv av stale design-eksperimenter — fjernes etter lansering
_archive/

# Lokal env/DB/cache — aldri commit
.env.local.backup-*
.env.local.tmp
.env.vercel-check
*.rvf
*.rvf.lock
ruvector.db
tsconfig.tsbuildinfo
.DS_Store
skills-lock.json

# Design-handover: alt design-arbeidsmateriale (store binærfiler, kilde for porting).
# Ligger lokalt + i Google Drive — for stort/binært for git, og serveres ikke i prod
# (kode refererer det kun i kommentarer som «fasit»). Besluttet 2026-06-04.
public/design-handover/
