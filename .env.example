# AK Golf HQ — environment variables
# Kopier denne filen til .env.local og fyll inn faktiske verdier.
# .env.local committes ALDRI til Git.

# ---------- Supabase ----------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Bypass-er Row Level Security. Aldri eksponer i klient-kode.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Database (Postgres via Supabase) ----------
# Project Settings → Database → Connection string
# DATABASE_URL: Transaction pooler (port 6543) — for runtime/queries
# DIRECT_URL:   Direct connection (port 5432) — for `prisma migrate`
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ---------- Anthropic (AI-coach) ----------
ANTHROPIC_API_KEY=

# ---------- Stripe ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------- Resend (transaksjons-e-post) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=ikke-svar@akgolf.no

# ---------- Cron (Vercel cron-jobber) ----------
CRON_SECRET=

# ---------- App URL ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Sentry (feilrapportering) ----------
# Public DSN — eksponeres i klient (det er greit, Sentry-design)
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload (kun i CI/Vercel — la stå tom lokalt)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---------- Plausible (analytics) ----------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=akgolf.no

# ---------- Google OAuth (valgfri — for "Logg inn med Google") ----------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://akgolf.no/api/auth/oauth-callback
GOOGLE_TOKEN_ENCRYPTION_KEY=
GOOGLE_WEBHOOK_TOKEN_SECRET=

# ---------- Booking ----------
# Brukes for å signere booking-utkast så de ikke kan tukles med
BOOKING_DRAFT_SECRET=

# ---------- Web Push (V2 — parkert) ----------
# Generer med: npx web-push generate-vapid-keys
# Den offentlige nøkkelen brukes i klient for å abonnere på push.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Den private nøkkelen brukes server-side for å sende push. Aldri eksponer.
VAPID_PRIVATE_KEY=
# Kontakt-email for VAPID-claims (mailto: prefix)
VAPID_SUBJECT=mailto:akgolfgroup@gmail.com
