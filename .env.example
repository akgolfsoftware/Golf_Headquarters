# AK Golf HQ — environment variables
# Kopier denne filen til .env.local og fyll inn faktiske verdier.
# .env.local committes ALDRI til Git.

# ---------- Supabase ----------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Bypass-er Row Level Security. Aldri eksponer i klient-kode.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Database (Postgres via Supabase) ----------
# Project Settings → Database → Connection string
# DATABASE_URL: Transaction pooler (port 6543) — for runtime/queries
# DIRECT_URL:   Direct connection (port 5432) — for `prisma migrate`
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ---------- Anthropic (AI-coach) ----------
ANTHROPIC_API_KEY=

# ---------- Vercel AI Gateway (Caddie chat-engine) ----------
# https://vercel.com/dashboard/ai-gateway → API keys
AI_GATEWAY_API_KEY=

# ---------- Stripe ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------- Resend (transaksjons-e-post) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=ikke-svar@akgolf.no

# ---------- Cron (Vercel cron-jobber) ----------
CRON_SECRET=

# ---------- Upstash Redis (rate-limit) ----------
# Opprett database på https://console.upstash.com/redis → REST API
# Hvis disse mangler er rate-limit no-op (greit for lokal dev, IKKE prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- App URL ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Sentry (feilrapportering) ----------
# Public DSN — eksponeres i klient (det er greit, Sentry-design)
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload (kun i CI/Vercel — la stå tom lokalt)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---------- Plausible (analytics) ----------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=akgolf.no

# ---------- Google OAuth (valgfri — for "Logg inn med Google") ----------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://akgolf.no/api/auth/oauth-callback
GOOGLE_TOKEN_ENCRYPTION_KEY=
GOOGLE_WEBHOOK_TOKEN_SECRET=

# ---------- Booking ----------
# Brukes for å signere booking-utkast så de ikke kan tukles med
BOOKING_DRAFT_SECRET=

# ---------- Mapbox (kart på /admin/anlegg) ----------
# Public token fra https://account.mapbox.com/access-tokens/.
# Eksponert i klient (det er greit — designet for browser-bruk, begrenset av URL-whitelist).
# Hvis tom: kartet viser fallback med tom-tilstand, listen fungerer som vanlig.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ---------- Web Push (V2 — parkert) ----------
# Generer med: npx web-push generate-vapid-keys
# Den offentlige nøkkelen brukes i klient for å abonnere på push.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Den private nøkkelen brukes server-side for å sende push. Aldri eksponer.
VAPID_PRIVATE_KEY=
# Kontakt-email for VAPID-claims (mailto: prefix)
VAPID_SUBJECT=mailto:akgolfgroup@gmail.com

# ---------- Feature flags (default: false until data is ready) ----------
NEXT_PUBLIC_FEATURE_LEADERBOARD=false
NEXT_PUBLIC_FEATURE_TRACKMAN_DETAIL=false
NEXT_PUBLIC_FEATURE_TALENT=false

# ---------- E2E-tester (Playwright) ----------
# Base-URL for Playwright. Default = http://localhost:3000.
# Sett til http://localhost:3002 hvis port 3000 er opptatt.
PLAYWRIGHT_BASE_URL=http://localhost:3000
# Seedet test-spiller for credit-booking + auth-guard E2E.
# Fyll inn for å kjøre disse testene; ellers skip-es de automatisk.
E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=

# SG Coaching Hub
DATAGOLF_API_KEY=

# ---------- Notion Sync (Internal Integration Token-flyt) ----------
# Opprett Internal Integration på https://www.notion.so/my-integrations
# Gi den Read/Update/Insert content + del Tasks-DB med integrasjonen
# (Tasks-DB → ··· → Connections → legg til integrasjonen).
NOTION_INTERNAL_TOKEN=

# AES-256-GCM krypteringsnøkkel (32 bytes hex) for token lagret i DB.
# Generer med: openssl rand -hex 32
NOTION_ENCRYPTION_KEY=

# (OAuth env-vars er fjernet — bruker Internal Token nå.)

# ---------- Stripe price-IDer (coaching-pakker) ----------
STRIPE_PRICE_ID_PERFORMANCE=
STRIPE_PRICE_ID_PERFORMANCE_PRO=

# ---------- Anthropic ekstra ----------
# Valgfri overstyring av API-base (normaliseres til .../v1 i caddie-ruten)
ANTHROPIC_BASE_URL=

# ---------- AK Golf Intelligence API (søster-tjeneste, master for DataGolf/WAGR) ----------
INTELLIGENCE_API_URL=https://ak-golf-intelligence.vercel.app
INTELLIGENCE_API_KEY=

# ---------- OpenAI (Whisper-transkribering av økt-opptak) ----------
OPENAI_API_KEY=

# ---------- YouTube Data API v3 (drill-forslag-agenten, best effort) ----------
YOUTUBE_API_KEY=

# ---------- E-postvarsling / kontakt ----------
ALERT_EMAIL=akgolfgroup@gmail.com
KONTAKT_MOTTAKER_EPOST=

# ---------- Innkommende e-post-webhook (/api/inbox/inbound) ----------
INBOX_WEBHOOK_SECRET=

# ---------- Meg-assistenten (eget Supabase-prosjekt + Telegram) ----------
MEG_SUPABASE_URL=
MEG_SUPABASE_SERVICE_ROLE_KEY=
MEG_TELEGRAM_BOT_TOKEN=
MEG_TELEGRAM_WEBHOOK_SECRET=
MEG_TELEGRAM_ALLOWED_CHAT_ID=
MEG_HEALTH_INGEST_SECRET=
# Embeddings (Voyage AI) for semantisk søk i Meg
MEG_EMBEDDINGS_API_KEY=
MEG_EMBEDDINGS_MODEL=voyage-3-lite
MEG_EMBEDDINGS_BASE_URL=https://api.voyageai.com/v1/embeddings
# Valgfrie modell-overstyringer
MEG_MODEL_SMART=
MEG_MODEL_FAST=
# Lokal LLM (valgfri)
MEG_OLLAMA_URL=
MEG_OLLAMA_MODEL=

# ---------- Kommando (multi-LLM chat, valgfrie) ----------
GEMINI_API_KEY=
XAI_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_API_KEY=

# ---------- Notion (legacy-flater som fortsatt leser disse) ----------
NOTION_API_KEY=
NOTION_PLAYER_DB_ID=
NOTION_COACHING_DB_ID=
NOTION_SB_TASKS_DB_ID=
NOTION_SB_PROJECTS_DB_ID=

# ---------- Booking (eksternt, inntil in-app booking er live) ----------
BOOKING_ACTIVE=false
NEXT_PUBLIC_ACUITY_URL=https://akgolfgroup.as.me
