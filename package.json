{
  "name": "akgolf-hq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "SERWIST_SUPPRESS_TURBOPACK_WARNING=1 prisma generate && SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
