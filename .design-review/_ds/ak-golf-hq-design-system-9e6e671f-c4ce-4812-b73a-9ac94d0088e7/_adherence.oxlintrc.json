{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/gamification/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Inter Tight|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Inter Tight, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|src|size|ring|presence|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, src, size, ring, presence."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='ring'] > Literal[value!=/^(?:lime|forest|neutral)$/]",
        "message": "<Avatar> ring must be one of 'lime' | 'forest' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='presence'] > Literal[value!=/^(?:online|away|busy|offline)$/]",
        "message": "<Avatar> presence must be one of 'online' | 'away' | 'busy' | 'offline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|lime|forest|ok|warn|urgent|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'lime' | 'forest' | 'ok' | 'warn' | 'urgent' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|disabled|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, disabled, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:lime|forest|ghost|terminal)$/]",
        "message": "<Button> variant must be one of 'lime' | 'forest' | 'ghost' | 'terminal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|body|action|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, body, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|lime|onDark)$/]",
        "message": "<Eyebrow> tone must be one of 'default' | 'lime' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|direction|fill|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, unit, delta, direction, fill."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<KpiCard> direction must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='fill'] > Literal[value!=/^(?:plain|forest|lime)$/]",
        "message": "<KpiCard> fill must be one of 'plain' | 'forest' | 'lime'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|label|color|key|ref|className|style|children)$/]",
        "message": "<KpiRing> doesn't accept that prop. Declared props: value, size, label, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='MasteryRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|progress|title|detail|size|key|ref|className|style|children)$/]",
        "message": "<MasteryRing> doesn't accept that prop. Declared props: level, progress, title, detail, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='PyramidProgress'] > JSXAttribute > JSXIdentifier[name!=/^(?:values|key|ref|className|style|children)$/]",
        "message": "<PyramidProgress> doesn't accept that prop. Declared props: values."
      },
      {
        "selector": "JSXOpeningElement[name.name='SgBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|category|value|max|key|ref|className|style|children)$/]",
        "message": "<SgBar> doesn't accept that prop. Declared props: name, category, value, max."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|height|radius|circle|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: width, height, radius, circle."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|numeric|tone|key|ref|className|style|children)$/]",
        "message": "<StatColumn> doesn't accept that prop. Declared props: key, label, numeric, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatColumn'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<StatColumn> tone must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|pulse|children|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: tone, pulse, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:active|behind|inactive|guide|warn|live)$/]",
        "message": "<StatusPill> tone must be one of 'active' | 'behind' | 'inactive' | 'guide' | 'warn' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreakTracker'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|unit|days|best|key|ref|className|style|children)$/]",
        "message": "<StreakTracker> doesn't accept that prop. Declared props: count, unit, days, best."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
